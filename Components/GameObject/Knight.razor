<g class="knight-group @StateClass" style="outline: none; cursor: pointer;">
    <style>
        .knight-group {
            image-rendering: pixelated;
        }
        /* Fixed Blazor string interpolation for CSS */
        .knight-group.idle {
            animation: knight-breathe 1.5s ease-in-out infinite alternate;
            transform-origin: bottom center;
        }
        .knight-group.walking {
            animation: knight-walk-bounce 0.4s linear infinite;
        }
        @@keyframes knight-breathe {
            from { transform: translateY(0px); }
            to { transform: translateY(4px); }
        }
        @@keyframes knight-walk-bounce {
            0%, 100% { transform: translateY(0px) scaleY(1); }
            50% { transform: translateY(-3px) scaleY(0.95); }
        }
    </style>

    <g transform="translate(10, -30)">
        <g class="premium-legs">
            <path d="M 22 110 L 34 110 L 36 142 L 18 142 Z" fill="#64748b" stroke="#1e293b" stroke-width="2" />
            <path d="M 22 118 L 34 118 L 32 135 L 24 135 Z" fill="#94a3b8" />
            <circle cx="27" cy="115" r="4" fill="#d97706" stroke="#1e293b" stroke-width="1.5" />
            <path d="M 46 110 L 58 110 L 62 142 L 44 142 Z" fill="#64748b" stroke="#1e293b" stroke-width="2" />
            <path d="M 46 118 L 58 118 L 56 135 L 48 135 Z" fill="#94a3b8" />
            <circle cx="53" cy="115" r="4" fill="#d97706" stroke="#1e293b" stroke-width="1.5" />
        </g>

        <g class="premium-torso">
            <rect x="18" y="50" width="44" height="60" fill="#334155" rx="4" />
            <path d="M 18 95 L 32 95 L 28 112 L 16 108 Z" fill="#b45309" stroke="#1e293b" stroke-width="2" />
            <path d="M 32 95 L 48 95 L 48 115 L 32 115 Z" fill="#d97706" stroke="#1e293b" stroke-width="2" />
            <path d="M 48 95 L 62 95 L 64 108 L 52 112 Z" fill="#b45309" stroke="#1e293b" stroke-width="2" />
            <path d="M 18 52 L 62 52 L 56 95 L 40 102 L 24 95 Z" fill="#64748b" stroke="#1e293b" stroke-width="2.5" />
            <path d="M 22 55 L 58 55 L 40 75 Z" fill="#d97706" stroke="#1e293b" stroke-width="1.5" />
            <path d="M 26 58 L 54 58 L 40 70 Z" fill="#fbbf24" />
            <line x1="40" y1="75" x2="40" y2="100" stroke="#1e293b" stroke-width="2" />
            <rect x="22" y="90" width="36" height="6" fill="#451a03" stroke="#1e293b" stroke-width="1.5" />
            <rect x="36" y="88" width="8" height="10" fill="#fbbf24" stroke="#1e293b" stroke-width="1.5" />

            <circle cx="16" cy="56" r="10" fill="#475569" stroke="#1e293b" stroke-width="2" />
            <circle cx="16" cy="56" r="7" fill="#d97706" />
            <path d="M 8 58 L 14 90 L 22 90 L 22 58 Z" fill="#64748b" stroke="#1e293b" stroke-width="2" />

            <g class="right-arm-assembly">
                <circle cx="64" cy="56" r="10" fill="#475569" stroke="#1e293b" stroke-width="2" />
                <circle cx="64" cy="56" r="7" fill="#d97706" />
                <path d="M 60 62 L 72 85 L 82 80 L 70 58 Z" fill="#64748b" stroke="#1e293b" stroke-width="2" />

                <g class="weapon-sword-vector" transform="translate(76, 80) rotate(15)">
                    <rect x="-3" y="0" width="6" height="18" fill="#b45309" stroke="#1e293b" stroke-width="1.5" rx="1" />
                    <circle cx="0" cy="16" r="4" fill="#d97706" stroke="#1e293b" stroke-width="1" />
                    <path d="M -16 0 L 16 0 L 12 -5 L -12 -5 Z" fill="#d97706" stroke="#1e293b" stroke-width="2" />
                    <path d="M -7 -5 L 7 -5 L 5 -75 L 0 -88 L -5 -75 Z" fill="url(#premiumBladeSteel)" stroke="#1e293b" stroke-width="2" />
                    <line x1="0" y1="-5" x2="0" y2="-84" stroke="#334155" stroke-width="1.5" />
                    <path d="M 0 -5 L 5 -5 L 3 -73 L 0 -84 Z" fill="#ffffff" opacity="0.2" />
                </g>
            </g>
        </g>

        <g class="premium-helmet" transform="translate(17, 3)">
            <path d="M 2 30 A 21 21 0 0 1 44 30 Z" fill="#475569" stroke="#1e293b" stroke-width="2.5" />
            <path d="M 2 30 L 5 44 L 23 52 L 41 44 L 44 30 Z" fill="#64748b" stroke="#1e293b" stroke-width="2.5" />
            <line x1="23" y1="0" x2="23" y2="52" stroke="#1e293b" stroke-width="2" />
            <path d="M 6 22 L 40 22 L 36 28 L 27 28 L 27 46 L 19 46 L 19 28 L 10 28 Z" fill="#d97706" stroke="#1e293b" stroke-width="1.5" />
            <path d="M 8 23 L 38 23 L 35 26 L 25 26 L 25 44 L 21 44 L 21 26 L 12 26 Z" fill="#fbbf24" />
            <rect x="10" y="24" width="11" height="3" fill="#111827" rx="1" />
            <rect x="25" y="24" width="11" height="3" fill="#111827" rx="1" />
            <circle cx="14" cy="36" r="1" fill="#1e293b" />
            <circle cx="16" cy="40" r="1" fill="#1e293b" />
            <circle cx="32" cy="36" r="1" fill="#1e293b" />
            <circle cx="30" cy="40" r="1" fill="#1e293b" />
        </g>
    </g>

    <defs>
        <linearGradient id="premiumBladeSteel" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="#94a3b8" />
            <stop offset="30%" stop-color="#cbd5e1" />
            <stop offset="70%" stop-color="#e2e8f0" />
            <stop offset="100%" stop-color="#475569" />
        </linearGradient>
    </defs>
</g>

@code {
    [Parameter] public string StateClass { get; set; } = "idle";
}