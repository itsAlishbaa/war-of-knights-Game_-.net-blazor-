<g class="skeleton-group @StateClass">
    <style>
        .skeleton-group {
            image-rendering: pixelated;
        }
        .skeleton-group.idle {
            animation: skeleton-breath 1.8s ease-in-out infinite;
        }
        .skeleton-group.attack .axe-group {
            animation: skeleton-slash 0.5s ease-in-out forwards;
            transform-origin: 74px 52px;
        }
        .skeleton-group.walk {
            animation: skeleton-bounce 0.6s linear infinite;
        }

        @@keyframes skeleton-breath {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(2px); }
        }
        @@keyframes skeleton-bounce {
            0%, 100% { transform: translateY(0px) rotate(0deg); }
            50% { transform: translateY(-3px) rotate(1deg); }
        }
        @@keyframes skeleton-slash {
            0% { transform: rotate(0deg); }
            50% { transform: rotate(-45deg); }
            100% { transform: rotate(20deg); }
        }
    </style>

    <g transform="translate(0, -90)">
        <g class="bony-legs">
            <rect x="37" y="104" width="6" height="35" fill="#f1f5f9" stroke="#475569" stroke-width="2" />
            <rect x="57" y="104" width="6" height="35" fill="#f1f5f9" stroke="#475569" stroke-width="2" />
        </g>

        <rect class="loincloth" x="32" y="94" width="36" height="12" fill="#b45309" stroke="#475569" stroke-width="2" rx="1" />

        <g class="ribcage-container">
            <rect x="47" y="40" width="6" height="55" fill="#cbd5e1" stroke="#475569" stroke-width="2" />
            <g class="ribs">
                <rect x="30" y="48" width="40" height="4" fill="#f1f5f9" stroke="#475569" stroke-width="2" rx="2" />
                <rect x="30" y="58" width="40" height="4" fill="#f1f5f9" stroke="#475569" stroke-width="2" rx="2" />
                <rect x="32" y="68" width="36" height="4" fill="#f1f5f9" stroke="#475569" stroke-width="2" rx="2" />
            </g>

            <path d="M 21 40 L 35 40 L 35 52 L 21 52 Z" fill="#64748b" stroke="#1e293b" stroke-width="2" />
            <path d="M 65 40 L 79 40 L 79 52 L 65 52 Z" fill="#64748b" stroke="#1e293b" stroke-width="2" />

            <rect x="23" y="52" width="6" height="25" fill="#f1f5f9" stroke="#475569" stroke-width="2" transform="rotate(15 26 52)" />

            <g class="axe-group">
                <rect x="71" y="52" width="6" height="25" fill="#f1f5f9" stroke="#475569" stroke-width="2" transform="rotate(-30 74 52)" />
                <g class="weapon-axe" transform="translate(72, 60) rotate(15)">
                    <rect x="-2" y="0" width="6" height="50" fill="url(#axeShaftGradient)" stroke="#1e293b" stroke-width="2" rx="1" />
                    <path d="M 4 -10 L 22 -18 L 22 2 L 4 -2 Z" fill="#475569" stroke="#1e293b" stroke-width="2" />
                    <path d="M 12 -14 L 20 -16 L 20 0 L 12 -2 Z" fill="#94a3b8" />
                </g>
            </g>
        </g>

        <g class="skull-container" transform="translate(27, 2)">
            <rect x="0" y="0" width="45" height="34" fill="#f1f5f9" stroke="#475569" stroke-width="3" rx="10" />
            <g class="eye-sockets">
                <rect x="8" y="12" width="8" height="8" fill="#000000" rx="4" />
                <circle cx="12" cy="16" r="2" fill="#ef4444" filter="url(#glow-effect)" />
                <rect x="29" y="12" width="8" height="8" fill="#000000" rx="4" />
                <circle cx="33" cy="16" r="2" fill="#ef4444" filter="url(#glow-effect)" />
            </g>
            <rect x="12" y="34" width="20" height="6" fill="#f1f5f9" stroke="#475569" stroke-width="2" />
            <line x1="17" y1="34" x2="17" y2="38" stroke="#475569" stroke-width="1.5" />
            <line x1="22" y1="34" x2="22" y2="38" stroke="#475569" stroke-width="1.5" />
            <line x1="27" y1="34" x2="27" y2="38" stroke="#475569" stroke-width="1.5" />
        </g>
    </g>

    <defs>
        <linearGradient id="axeShaftGradient" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#94a3b8" />
            <stop offset="100%" stop-color="#475569" />
        </linearGradient>
        <filter id="glow-effect" x="-50%" y="-50%" width="200%" height="200%">
            <feGaussianBlur stdDeviation="1" result="blur" />
            <feMerge>
                <feMergeNode in="blur" />
                <feMergeNode in="SourceGraphic" />
            </feMerge>
        </filter>
    </defs>
</g>

@code {
    [Parameter] public string StateClass { get; set; } = "idle";
}