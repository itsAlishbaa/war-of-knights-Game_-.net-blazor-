            <button class="ctrl-btn attack-btn" onclick="knightAttack()">⚔ ATTACK</button>
            <button class="ctrl-btn block-btn" id="blockBtn" onmousedown="startBlock()" onmouseup="stopBlock()" ontouchstart="startBlock()" ontouchend="stopBlock()">🛡 BLOCK</button>
            <div class="ctrl-sep"></div>
