    <script>
            // ==========================================
            // SQL-STYLE DATABASE (localStorage)
            // Simulates: Users table, Matches table
            // ==========================================
            const DB = {
              // CREATE TABLE users (id, username, email, password, created_at, last_login, wins, losses, streak, best_streak, dragon_kills)
              // CREATE TABLE matches (id, user_id, level, enemy, result, date)

              init() {
                if (!localStorage.getItem('ic_db_users')) localStorage.setItem('ic_db_users', JSON.stringify([]));
                if (!localStorage.getItem('ic_db_matches')) localStorage.setItem('ic_db_matches', JSON.stringify([]));
                if (!localStorage.getItem('ic_settings')) localStorage.setItem('ic_settings', JSON.stringify({dark:true,light:false,colorblind:false}));
              },

              // INSERT INTO users
              insertUser(username, email, password) {
                const users = this.selectAllUsers();
                if (users.find(u => u.username.toLowerCase() === username.toLowerCase()))
                  return {ok:false, msg:'Username already exists'};
                if (users.find(u => u.email.toLowerCase() === email.toLowerCase()))
                  return {ok:false, msg:'Email already registered'};
                const user = {
                  id: Date.now(), username, email,
                  password: btoa(password), // base64 encode (simple hash sim)
                  created_at: new Date().toLocaleDateString('en-PK'),
                  last_login: new Date().toLocaleString('en-PK'),
                  wins:0, losses:0, streak:0, best_streak:0, dragon_kills:0
                };
                users.push(user);
                localStorage.setItem('ic_db_users', JSON.stringify(users));
                return {ok:true, user};
              },

              // SELECT * FROM users WHERE username=? AND password=?
              loginUser(username, password) {
                const users = this.selectAllUsers();
                const user = users.find(u => u.username.toLowerCase() === username.toLowerCase() && u.password === btoa(password));
                if (!user) return {ok:false, msg:'Invalid username or password'};
                // UPDATE last_login
                user.last_login = new Date().toLocaleString('en-PK');
                localStorage.setItem('ic_db_users', JSON.stringify(users));
                return {ok:true, user};
              },

              selectAllUsers() { return JSON.parse(localStorage.getItem('ic_db_users') || '[]'); },

              // SELECT * FROM users WHERE id=?
              getUserById(id) { return this.selectAllUsers().find(u => u.id === id); },

              // UPDATE users SET wins/losses/streak WHERE id=?
              updateUserStats(userId, won, level) {
                const users = this.selectAllUsers();
                const u = users.find(u => u.id === userId);
                if (!u) return;
                if (won) { u.wins++; u.streak++; if(u.streak > u.best_streak) u.best_streak = u.streak; if(level===3) u.dragon_kills++; }
                else { u.losses++; u.streak = 0; }
                localStorage.setItem('ic_db_users', JSON.stringify(users));
              },

              // INSERT INTO matches
              insertMatch(userId, level, enemy, result) {
                const matches = this.selectAllMatches();
                matches.push({ id: Date.now(), userId, level, enemy, result, date: new Date().toLocaleDateString('en-PK') });
                localStorage.setItem('ic_db_matches', JSON.stringify(matches));
              },

              selectAllMatches() { return JSON.parse(localStorage.getItem('ic_db_matches') || '[]'); },

              // SELECT * FROM matches WHERE userId=? ORDER BY id DESC
              getMatchesByUser(userId) { return this.selectAllMatches().filter(m => m.userId === userId).reverse(); },

              getSettings() { return JSON.parse(localStorage.getItem('ic_settings') || '{}'); },
              saveSettings(s) { localStorage.setItem('ic_settings', JSON.stringify(s)); },

              getCurrentUser() { const id = localStorage.getItem('ic_current'); return id ? this.getUserById(parseInt(id)) : null; },
              setCurrentUser(id) { localStorage.setItem('ic_current', id); },
              clearCurrentUser() { localStorage.removeItem('ic_current'); }
            };

            // ==========================================
            // APP STATE
            // ==========================================
            let currentSection = 'home';
            let gameState = null;
            let gameLoop = null;
            let enemyLoop = null;
            let fireLoop = null;
            let paused = false;
            let blocking = false;
            let currentLevel = 1;

            // ==========================================
            // INIT
            // ==========================================
            DB.init();
            createStars('lndStars', 80);
            createParticles();
            loadSettings();

            // Check if already logged in
            const autoUser = DB.getCurrentUser();
            if (autoUser) enterApp(autoUser);

            // ==========================================
            // STARS
            // ==========================================
            function createStars(containerId, count) {
              const c = document.getElementById(containerId);
              if (!c) return;
              for (let i = 0; i < count; i++) {
                const s = document.createElement('div');
                s.className = 'lnd-star';
                const size = Math.random() * 3 + 1;
                s.style.cssText = `width:${size}px;height:${size}px;top:${Math.random()*100}%;left:${Math.random()*100}%;animation-delay:${Math.random()*3}s;animation-duration:${2+Math.random()*3}s`;
                c.appendChild(s);
              }
            }

            function createGameStars() {
              const c = document.getElementById('gStars');
              if (!c) return;
              c.innerHTML = '';
              for (let i = 0; i < 50; i++) {
                const s = document.createElement('div');
                s.className = 'star-g';
                const size = Math.random() * 2.5 + .5;
                s.style.cssText = `position:absolute;width:${size}px;height:${size}px;top:${Math.random()*65}%;left:${Math.random()*100}%;animation-delay:${Math.random()*3}s;animation-duration:${2+Math.random()*3}s`;
                c.appendChild(s);
              }
            }

            function createParticles() {
              const c = document.getElementById('lndParticles');
              if (!c) return;
              const colors = ['rgba(240,192,64,.6)','rgba(200,120,10,.5)','rgba(255,200,100,.4)'];
              for (let i = 0; i < 20; i++) {
                const p = document.createElement('div');
                p.className = 'lnd-particle';
                const size = Math.random() * 8 + 3;
                p.style.cssText = `width:${size}px;height:${size}px;background:${colors[Math.floor(Math.random()*3)]};left:${Math.random()*100}%;animation-duration:${6+Math.random()*10}s;animation-delay:${Math.random()*8}s`;
                c.appendChild(p);
              }
            }

            // ==========================================
            // NAVIGATION
            // ==========================================
            function showPage(id) {
              document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
              document.getElementById(id).classList.add('active');
            }

            function goToAuth() { showPage('pg-auth'); }

            function showSection(name) {
              document.querySelectorAll('main section').forEach(s => s.classList.add('sec-hidden'));
              document.getElementById('sec-' + name).classList.remove('sec-hidden');
              document.querySelectorAll('.drawer-link').forEach(l => l.classList.remove('active'));
              document.getElementById('dl-' + name).classList.add('active');
              currentSection = name;
              if (name === 'profile') loadProfileData();
            }

            // ==========================================
            // AUTH
            // ==========================================
            function switchAuthTab(tab) {
              document.getElementById('tab-login').classList.toggle('active', tab === 'login');
              document.getElementById('tab-reg').classList.toggle('active', tab === 'register');
              document.getElementById('form-login').classList.toggle('hidden', tab !== 'login');
              document.getElementById('form-reg').classList.toggle('hidden', tab !== 'register');
            }

            function showMsg(id, msg, type) {
              const el = document.getElementById(id);
              el.style.display = 'block';
              el.className = 'auth-msg ' + type;
              el.textContent = msg;
            }

            function doRegister() {
              const u = document.getElementById('reg-user').value.trim();
              const e = document.getElementById('reg-email').value.trim();
              const p = document.getElementById('reg-pass').value;
              if (!u || !e || !p) return showMsg('reg-msg', 'Please fill all fields', 'error');
              if (p.length < 4) return showMsg('reg-msg', 'Password must be 4+ characters', 'error');
              const res = DB.insertUser(u, e, p);
              if (!res.ok) return showMsg('reg-msg', res.msg, 'error');
              showMsg('reg-msg', '✔ Account created! Logging in...', 'success');
              setTimeout(() => enterApp(res.user), 1000);
            }

            function doLogin() {
              const u = document.getElementById('login-user').value.trim();
              const p = document.getElementById('login-pass').value;
              if (!u || !p) return showMsg('login-msg', 'Please fill all fields', 'error');
              const res = DB.loginUser(u, p);
              if (!res.ok) return showMsg('login-msg', res.msg, 'error');
              enterApp(res.user);
            }

            function enterApp(user) {
              DB.setCurrentUser(user.id);
              // Update drawer
              const initials = user.username.slice(0,2).toUpperCase();
              document.getElementById('drawer-avatar').textContent = initials;
              document.getElementById('drawer-username').textContent = user.username;
              // Load home stats
              loadHomeStats(user);
              showPage('pg-main');
              showSection('home');
              showNotif(`Welcome back, ${user.username}! ⚔`, 'info');
            }

            function doLogout() {
              DB.clearCurrentUser();
              showPage('pg-auth');
              showNotif('Logged out successfully', 'info');
            }

            // ==========================================
            // HOME STATS
            // ==========================================
            function loadHomeStats(user) {
              if (!user) user = DB.getCurrentUser();
              if (!user) return;
              document.getElementById('hs-wins').textContent = user.wins;
              document.getElementById('hs-losses').textContent = user.losses;
              document.getElementById('hs-matches').textContent = user.wins + user.losses;
              document.getElementById('hs-streak').textContent = user.best_streak;
            }

            // ==========================================
            // PROFILE
            // ==========================================
            function loadProfileData() {
              const user = DB.getCurrentUser();
              if (!user) return;
              const initials = user.username.slice(0,2).toUpperCase();
              document.getElementById('prof-avatar').textContent = initials;
              document.getElementById('prof-name').textContent = user.username;
              document.getElementById('prof-join').textContent = user.created_at;
              document.getElementById('prof-login').textContent = user.last_login;
              document.getElementById('prof-email').textContent = user.email;
              document.getElementById('ps-total').textContent = user.wins + user.losses;
              document.getElementById('ps-wins').textContent = user.wins;
              document.getElementById('ps-losses').textContent = user.losses;
              const total = user.wins + user.losses;
              document.getElementById('ps-rate').textContent = total ? Math.round(user.wins/total*100) + '%' : '0%';
              document.getElementById('ps-streak').textContent = user.best_streak;
              document.getElementById('ps-lvl3').textContent = user.dragon_kills;
              // Match history
              const matches = DB.getMatchesByUser(user.id).slice(0, 15);
              const tbody = document.getElementById('match-tbody');
              if (matches.length === 0) {
                tbody.innerHTML = '<tr><td colspan="4" style="text-align:center;color:var(--gray);padding:1rem">No matches yet. Start playing!</td></tr>';
                return;
              }
              tbody.innerHTML = matches.map(m => `
                <tr>
                  <td>${m.enemy}</td>
                  <td>Level ${m.level}</td>
                  <td><span class="${m.result==='WIN'?'win-badge':'lose-badge'}">${m.result}</span></td>
                  <td>${m.date}</td>
                </tr>`).join('');
            }

            // ==========================================
            // SETTINGS
            // ==========================================
            function loadSettings() {
              const s = DB.getSettings();
              document.getElementById('tog-dark').checked = !!s.dark;
              document.getElementById('tog-light').checked = !!s.light;
              document.getElementById('tog-colorblind').checked = !!s.colorblind;
              applyTheme();
            }

            function applyTheme() {
              const dark = document.getElementById('tog-dark').checked;
              const light = document.getElementById('tog-light').checked;
              const cb = document.getElementById('tog-colorblind').checked;
              DB.saveSettings({dark, light, colorblind: cb});
              document.body.classList.toggle('light-theme', light && !dark);
              document.body.classList.toggle('colorblind-theme', cb);
            }

            // ==========================================
            // GAME ENGINE
            // ==========================================
            const LEVELS = {
              1: { name:'The Skeleton Crypt', badge:'LEVEL 1 — EASY', enemy:'skeleton', enemyLabel:'💀 SKELETON', knightHP:150, enemyHP:80, enemyAtk:[8,14], knightAtk:[15,22], fireCooldown:4000, fireAtk:[10,16], enemyAtkCooldown:2000, label:'Skeleton', score:100 },
              2: { name:'The Undead Warrior', badge:'LEVEL 2 — MEDIUM', enemy:'warrior', enemyLabel:'💂 WARRIOR', knightHP:120, enemyHP:130, enemyAtk:[18,25], knightAtk:[18,26], fireCooldown:3000, fireAtk:[15,22], enemyAtkCooldown:1600, label:'Warrior', score:200 },
              3: { name:'The Dragon\'s Lair', badge:'LEVEL 3 — HARD', enemy:'dragon', enemyLabel:'🐉 DRAGON', knightHP:100, enemyHP:200, enemyAtk:[25,40], knightAtk:[20,30], fireCooldown:2000, fireAtk:[20,35], enemyAtkCooldown:1200, label:'Dragon', score:400 }
            };

            function startGame(level) {
              currentLevel = level;
              const cfg = LEVELS[level];
              gameState = {
                knightHP: cfg.knightHP, knightMaxHP: cfg.knightHP,
                enemyHP: cfg.enemyHP, enemyMaxHP: cfg.enemyHP,
                score: 0, paused: false, over: false,
                blocking: false, level
              };
              paused = false;
              blocking = false;

              // Setup UI
              document.getElementById('hud-level-badge').textContent = cfg.badge;
              document.getElementById('enemy-label').textContent = cfg.enemyLabel;
              document.getElementById('enemy-fighter-label').textContent = cfg.label.toUpperCase();

              // Show correct enemy
              ['skeleton','warrior','dragon'].forEach(e => document.getElementById('enemy-' + e).style.display = 'none');
              document.getElementById('enemy-' + cfg.enemy).style.display = 'block';

              // Stats panel
              document.getElementById('kp-hp').textContent = cfg.knightHP;
              document.getElementById('kp-atk').textContent = cfg.knightAtk[0] + '-' + cfg.knightAtk[1];
              document.getElementById('kp-def').textContent = level === 1 ? 8 : level === 2 ? 10 : 12;
              document.getElementById('kp-block').textContent = 'false';
              document.getElementById('ep-hp').textContent = cfg.enemyHP;
              document.getElementById('ep-atk').textContent = cfg.enemyAtk[0] + '-' + cfg.enemyAtk[1];
              document.getElementById('ep-fire').textContent = (cfg.fireCooldown/1000) + 's';
              document.getElementById('ep-type').textContent = cfg.enemy;

              updateHUD();
              document.getElementById('combatLog').innerHTML = '';
              hideOverlay();
              createGameStars();
              showPage('pg-game');

              logCombat(`⚔ Battle begins! Knight vs ${cfg.label}!`, '');

              // Enemy attack loop
              clearInterval(enemyLoop);
              enemyLoop = setInterval(() => {
                if (!gameState || gameState.over || gameState.paused) return;
                enemyAttack();
              }, cfg.enemyAtkCooldown);

              // Fire loop
              clearInterval(fireLoop);
              fireLoop = setInterval(() => {
                if (!gameState || gameState.over || gameState.paused) return;
                enemyFireball();
              }, cfg.fireCooldown);
            }

            function updateHUD() {
              if (!gameState) return;
              const cfg = LEVELS[gameState.level];
              const kPct = Math.max(0, gameState.knightHP / gameState.knightMaxHP * 100);
              const ePct = Math.max(0, gameState.enemyHP / gameState.enemyMaxHP * 100);
              document.getElementById('knight-hp-bar').style.width = kPct + '%';
              document.getElementById('enemy-hp-bar').style.width = ePct + '%';
              document.getElementById('knight-hp-txt').textContent = Math.max(0, gameState.knightHP) + ' / ' + gameState.knightMaxHP;
              document.getElementById('enemy-hp-txt').textContent = Math.max(0, gameState.enemyHP) + ' / ' + gameState.enemyMaxHP;
              document.getElementById('hud-score').textContent = gameState.score;
              document.getElementById('kp-hp').textContent = Math.max(0, gameState.knightHP);
              document.getElementById('ep-hp').textContent = Math.max(0, gameState.enemyHP);
              document.getElementById('kp-block').textContent = blocking ? 'true' : 'false';
              // HP bar color
              const kBar = document.getElementById('knight-hp-bar');
              if (kPct < 25) kBar.style.background = 'linear-gradient(90deg,#8a0f0f,var(--hp-red))';
              else if (kPct < 50) kBar.style.background = 'linear-gradient(90deg,#8a5a00,#fb8500)';
              else kBar.style.background = 'linear-gradient(90deg,#1a7a3a,var(--hp-green))';
            }

            function rand(min, max) { return Math.floor(Math.random() * (max - min + 1)) + min; }

            function knightAttack() {
              if (!gameState || gameState.over || gameState.paused) return;
              const cfg = LEVELS[gameState.level];
              const dmg = rand(cfg.knightAtk[0], cfg.knightAtk[1]);
              gameState.enemyHP -= dmg;
              gameState.score += Math.floor(dmg * 1.5);

              // Sword swing animation
              const sw = document.getElementById('kSword');
              sw.classList.add('attacking');
              setTimeout(() => sw.classList.remove('attacking'), 450);

              // Hit effect on enemy
              const ef = document.getElementById('enemy-' + cfg.enemy);
              ef.style.filter = 'brightness(2) saturate(2)';
              setTimeout(() => ef.style.filter = '', 200);

              logCombat(`⚔ Knight attacks for ${dmg} damage!`, 'dmg');
              showHitText('-' + dmg + ' ⚔', '#ff6644', true);

              if (gameState.enemyHP <= 0) {
                gameState.enemyHP = 0;
                updateHUD();
                endGame(true);
              } else {
                updateHUD();
              }
            }

            function enemyAttack() {
              if (!gameState || gameState.over || gameState.paused) return;
              const cfg = LEVELS[gameState.level];
              let dmg = rand(cfg.enemyAtk[0], cfg.enemyAtk[1]);

              // Ax animation
              const axId = cfg.enemy === 'warrior' ? 'warAx' : (cfg.enemy === 'skeleton' ? 'skAx' : null);
              if (axId) {
                const ax = document.getElementById(axId);
                ax.classList.add('attacking');
                setTimeout(() => ax.classList.remove('attacking'), 480);
              }

              if (blocking) {
                const blocked = Math.floor(dmg * 0.75);
                dmg -= blocked;
                logCombat(`🛡 Knight blocks! Only ${dmg} damage taken!`, 'block');
                const sh = document.getElementById('kShield');
                sh.classList.add('blocking');
                setTimeout(() => sh.classList.remove('blocking'), 400);
                showHitText('BLOCKED! -' + dmg, '#4aa8ff', false);
              } else {
                logCombat(`💥 ${cfg.label} attacks for ${dmg} damage!`, 'dmg');
                flashScreen();
                showHitText('-' + dmg + ' 💥', '#ff3333', false);
              }

              gameState.knightHP -= dmg;
              if (gameState.knightHP <= 0) {
                gameState.knightHP = 0;
                updateHUD();
                endGame(false);
              } else {
                updateHUD();
              }
            }

            function enemyFireball() {
              if (!gameState || gameState.over || gameState.paused) return;
              const cfg = LEVELS[gameState.level];
              const fireId = cfg.enemy === 'warrior' ? 'warFire' : (cfg.enemy === 'skeleton' ? 'skFire' : 'drFire');
              const fireEl = document.getElementById(fireId);
              if (fireEl) {
                fireEl.classList.add('active');
                setTimeout(() => fireEl.classList.remove('active'), 700);
              }

              // Launch projectile emoji
              const proj = document.createElement('div');
              proj.className = 'projectile';
              proj.textContent = cfg.enemy === 'dragon' ? '🔥' : '🔥';
              proj.style.cssText = 'right:30%;top:42%;animation-duration:.8s';
              const arena = document.getElementById('gameArena');
              arena.appendChild(proj);

              // Move projectile
              let pos = 30;
              const moveProj = setInterval(() => {
                pos += 4;
                proj.style.right = pos + '%';
                if (pos >= 75) {
                  clearInterval(moveProj);
                  proj.remove();
                  // Apply damage
                  if (!gameState || gameState.over) return;
                  if (blocking) {
                    logCombat(`🛡 Shield deflects the fireball!`, 'block');
                    showHitText('SHIELD! 🛡', '#4aa8ff', false);
                    gameState.score += 20;
                  } else {
                    const fireDmg = rand(cfg.fireAtk[0], cfg.fireAtk[1]);
                    gameState.knightHP -= fireDmg;
                    logCombat(`🔥 Fireball hits for ${fireDmg} damage!`, 'fire');
                    flashScreen();
                    showHitText('-' + fireDmg + ' 🔥', '#ff8800', false);
                    if (gameState.knightHP <= 0) { gameState.knightHP = 0; updateHUD(); endGame(false); return; }
                  }
                  updateHUD();
                }
              }, 40);
            }

            function startBlock() {
              if (!gameState || gameState.over || gameState.paused) return;
              blocking = true;
              gameState.blocking = true;
              document.getElementById('kShield').classList.add('blocking');
              document.getElementById('kp-block').textContent = 'true';
              document.getElementById('blockBtn').style.background = 'rgba(67,97,238,.3)';
            }
            function stopBlock() {
              blocking = false;
              if (gameState) gameState.blocking = false;
              document.getElementById('kShield').classList.remove('blocking');
              if (gameState) document.getElementById('kp-block').textContent = 'false';
              document.getElementById('blockBtn').style.background = '';
            }

            function moveKnight(dir) {
              if (!gameState || gameState.over || gameState.paused) return;
              const kw = document.querySelector('.knight-wrap');
              if (!kw) return;
              const cur = parseInt(kw.style.marginLeft || 0);
              kw.style.marginLeft = (cur + dir * 20) + 'px';
              gameState.score += 2;
              logCombat(`Knight moves ${dir > 0 ? 'forward' : 'backward'}`, '');
            }

            function flashScreen() {
              const fl = document.getElementById('dmgFlash');
              fl.style.animation = 'none';
              fl.offsetHeight;
              fl.style.animation = 'flashFade .4s ease forwards';
            }

            function showHitText(text, color, onEnemy) {
              const arena = document.getElementById('gameArena');
              const el = document.createElement('div');
              el.className = 'hit-text';
              el.textContent = text;
              el.style.cssText = `color:${color};font-size:1.3rem;${onEnemy?'right:28%;':'left:18%;'}top:${rand(35,55)}%;text-shadow:0 0 10px ${color}`;
              arena.appendChild(el);
              setTimeout(() => el.remove(), 1100);
            }

            function logCombat(msg, cls) {
              const log = document.getElementById('combatLog');
              const p = document.createElement('p');
              p.className = cls;
              p.textContent = msg;
              log.prepend(p);
              if (log.children.length > 12) log.lastChild.remove();
            }

            // ==========================================
            // GAME END
            // ==========================================
            function endGame(won) {
              if (!gameState || gameState.over) return;
              gameState.over = true;
              clearInterval(enemyLoop);
              clearInterval(fireLoop);
              stopBlock();

              const cfg = LEVELS[gameState.level];
              const user = DB.getCurrentUser();

              if (user) {
                DB.updateUserStats(user.id, won, gameState.level);
                DB.insertMatch(user.id, gameState.level, cfg.label, won ? 'WIN' : 'LOSE');
                loadHomeStats();
              }

              const overlay = document.getElementById('gameOverlay');
              overlay.classList.add('show');

              const title = document.getElementById('ovTitle');
              const sub = document.getElementById('ovSub');

              document.getElementById('ovResume').style.display = 'none';
              document.getElementById('ovReplay').style.display = 'inline-block';

              if (won) {
                title.style.color = 'var(--green)';
                title.textContent = '⚔ VICTORY!';
                sub.textContent = `You defeated the ${cfg.label}! Score: ${gameState.score} pts`;
                const nextBtn = document.getElementById('ovNext');
                if (currentLevel < 3) {
                  nextBtn.style.display = 'inline-block';
                } else {
                  nextBtn.style.display = 'none';
                  sub.textContent = `🏆 You beat ALL levels! Legendary Knight! Score: ${gameState.score} pts`;
                }
              } else {
                title.style.color = 'var(--red)';
                title.textContent = '💀 DEFEATED!';
                sub.textContent = `The ${cfg.label} was too powerful... Score: ${gameState.score} pts`;
                document.getElementById('ovNext').style.display = 'none';
              }
            }

            function togglePause() {
              if (!gameState || gameState.over) return;
              paused = !paused;
              gameState.paused = paused;
              if (paused) {
                document.getElementById('ovTitle').style.color = 'var(--gold)';
                document.getElementById('ovTitle').textContent = '⏸ PAUSED';
                document.getElementById('ovSub').textContent = 'Take a breath, Knight';
                document.getElementById('ovResume').style.display = 'inline-block';
                document.getElementById('ovNext').style.display = 'none';
                document.getElementById('ovReplay').style.display = 'none';
                document.getElementById('gameOverlay').classList.add('show');
              } else {
                resumeGame();
              }
            }

            function resumeGame() {
              paused = false;
              if (gameState) gameState.paused = false;
              hideOverlay();
            }

            function hideOverlay() {
              document.getElementById('gameOverlay').classList.remove('show');
            }

            function goNextLevel() {
              if (currentLevel < 3) startGame(currentLevel + 1);
            }

            function replayLevel() {
              startGame(currentLevel);
            }

            function exitGame() {
              clearInterval(enemyLoop);
              clearInterval(fireLoop);
              stopBlock();
              gameState = null;
              paused = false;
              showPage('pg-main');
              showSection('home');
              loadHomeStats();
            }

            // ==========================================
            // NOTIFICATIONS
            // ==========================================
            function showNotif(msg, type) {
              const n = document.createElement('div');
              n.className = `notif notif-${type}`;
              n.textContent = msg;
              document.body.appendChild(n);
              setTimeout(() => n.remove(), 3200);
            }

            // ==========================================
            // KEYBOARD CONTROLS
            // ==========================================
            document.addEventListener('keydown', e => {
              if (!gameState || gameState.over) return;
              const k = e.key.toLowerCase();
              if (k === 'a' || k === 'arrowleft') moveKnight(-1);
              else if (k === 'd' || k === 'arrowright') moveKnight(1);
              else if (k === ' ' || k === 'enter') { e.preventDefault(); knightAttack(); }
              else if (k === 's' || k === 'arrowdown') startBlock();
              else if (k === 'p' || k === 'escape') togglePause();
            });
            document.addEventListener('keyup', e => {
              if (e.key.toLowerCase() === 's' || e.key === 'ArrowDown') stopBlock();
            });
    </script>
</body>
</html>
