@page "/"
@using final_pro_c.Models
@using final_pro_c.Services
@* UNCOMMENT THIS WHEN SQL IS READY *@
@* @using IronCrusadeBlazor.Data *@
@inject GameEngineService Engine
@* @inject AppDbContext Db *@
@implements IDisposable
@rendermode InteractiveServer

<style>
    /* Real-time Dynamic Fighter Animations to fix the static look */
    .fighter {
        transition: all 0.15s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }
    .knight-dash-attack {
        animation: knightStrike 0.15s ease-in-out forwards;
    }
    .enemy-dash-attack {
        animation: enemyStrike 0.15s ease-in-out forwards;
    }
    @@keyframes knightStrike {
        0% { transform: scale(1) translateX(0); }
        50% { transform: scale(1.05) translateX(35px) rotate(4deg); }
        100% { transform: scale(1) translateX(0); }
    }
    @@keyframes enemyStrike {
        0% { transform: scale(1) translateX(0); }
        50% { transform: scale(1.05) translateX(-45px) rotate(-6deg); }
        100% { transform: scale(1) translateX(0); }
    }
    .hit-shake {
        animation: hurtShake 0.2s ease-in-out;
    }
    @@keyframes hurtShake {
        0% { transform: translateX(0); }
        25% { transform: translateX(-10px); }
        50% { transform: translateX(10px); }
        75% { transform: translateX(-5px); }
        100% { transform: translateX(0); }
    }
</style>

<div class="app-container @(IsLightStyle ? "light-theme" : "") @(IsColorblindStyle ? "colorblind-theme" : "")">
    
    @* NOTIFICATION SYSTEM *@
    @foreach (var notif in Notifications.ToList())
    {
        <div class="notif notif-@notif.Type">@notif.Message</div>
    }

    @* DRAWER NAVIGATION CONTROLLER *@
    @if (IsAppScreenActive)
    {
        <aside class="drawer">
            <div class="drawer-header">
                <div class="drawer-avatar">@UserInitials</div>
                <div class="drawer-info">
                    <div class="drawer-username">@CurrentUser?.Username</div>
                    <div class="drawer-status">🟢 Online</div>
                </div>
            </div>
            <nav class="drawer-menu">
                <button class="drawer-link @(ActiveTab == "home" ? "active" : "")" @onclick='() => SetTab("home")'>🏰 Citadel Home</button>
                <button class="drawer-link @(ActiveTab == "profile" ? "active" : "")" @onclick='() => SetTab("profile")'>🛡️ Player Profile</button>
                <button class="drawer-link @(ActiveTab == "settings" ? "active" : "")" @onclick='() => SetTab("settings")'>⚙ Settings</button>
                <button class="drawer-link logout-link" @onclick="LogOut">✕ Disconnect</button>
            </nav>
        </aside>
    }

    <main class="main-content">
        @* ------------------ AUTH PAGE ------------------ *@
        @if (CurrentView == ViewState.Auth)
        {
            <div class="auth-box">
                <h2 class="auth-title">⚔ BATTLE OF KNIGHT</h2>
                <div class="auth-tabs">
                    <button class="auth-tab @(IsLoginTab ? "active" : "")" @onclick="() => IsLoginTab = true">LOGIN</button>
                    <button class="auth-tab @(!IsLoginTab ? "active" : "")" @onclick="() => IsLoginTab = false">REGISTER</button>
                </div>

                @if (!string.IsNullOrEmpty(AuthErrorMessage))
                {
                    <div class="auth-msg error">@AuthErrorMessage</div>
                }

                @if (IsLoginTab)
                {
                    <div class="auth-form">
                        <input type="text" placeholder="Username" @bind="AuthUsername" class="auth-input" />
                        <input type="password" placeholder="Password" @bind="AuthPassword" class="auth-input" />
                        <button class="auth-btn" @onclick="HandleLogin">ENTER THE REALM</button>
                    </div>
                }
                else
                {
                    <div class="auth-form">
                        <input type="text" placeholder="Choose Username" @bind="AuthUsername" class="auth-input" />
                        <input type="email" placeholder="Your Email" @bind="AuthEmail" class="auth-input" />
                        <input type="password" placeholder="Secure Password" @bind="AuthPassword" class="auth-input" />
                        <button class="auth-btn" @onclick="HandleRegister">CREATE ACCT</button>
                    </div>
                }
            </div>
        }

        @* ------------------ MAIN DASHBOARD ------------------ *@
        @if (CurrentView == ViewState.MainApp)
        {
            @if (ActiveTab == "home")
            {
                <div class="welcome-banner">
                    <h1>Welcome, Vanguard @CurrentUser?.Username!</h1>
                    <p>The dark lands await your deployment. Choose a level to begin.</p>
                </div>

                <div class="dashboard-stats">
                    <div class="stat-box"><h3>@CurrentUser?.Wins</h3><p>Victories</p></div>
                    <div class="stat-box"><h3>@CurrentUser?.Losses</h3><p>Defeats</p></div>
                    <div class="stat-box"><h3>@(CurrentUser!.Wins + CurrentUser.Losses)</h3><p>Battles Played</p></div>
                    <div class="stat-box"><h3>@CurrentUser?.BestStreak</h3><p>Best Streak</p></div>
                </div>

                <h2 class="section-heading">⚔ Deploy to Campaign</h2>
                <div class="level-select-grid">
                    <div class="level-card card-easy" @onclick="() => StartBattle(1)">
                        <div class="lvl-num">LVL 1</div><h3>The Skeleton Crypt</h3><p>Difficulty: Easy</p>
                    </div>
                    <div class="level-card card-medium" @onclick="() => StartBattle(2)">
                        <div class="lvl-num">LVL 2</div><h3>The Undead Warrior</h3><p>Difficulty: Medium</p>
                    </div>
                    <div class="level-card card-hard" @onclick="() => StartBattle(3)">
                        <div class="lvl-num">LVL 3</div><h3>The Dragon's Lair</h3><p>Difficulty: Hard</p>
                    </div>
                </div>
            }
            else if (ActiveTab == "profile")
            {
                <div class="profile-card">
                    <div class="profile-avatar-big">@UserInitials</div>
                    <div class="profile-info">
                        <div class="profile-name-big">@CurrentUser?.Username</div>
                        <div class="profile-role">🛡️ Knight of the Crusade</div>
                        <div class="profile-date">Joined: <span>@CurrentUser?.CreatedAt</span></div>
                        <div class="profile-date">Email: <span>@CurrentUser?.Email</span></div>
                    </div>
                </div>

                <div class="match-history-title">⚔ Match History Records</div>
                <table class="match-table">
                    <thead><tr><th>Opponent</th><th>Level</th><th>Result</th><th>Date</th></tr></thead>
                    <tbody>
                        @if (!MatchHistories.Any())
                        {
                            <tr><td colspan="4" style="text-align:center;color:var(--gray)">No chronicles recorded yet.</td></tr>
                        }
                        @foreach (var entry in MatchHistories)
                        {
                            <tr>
                                <td>@entry.Enemy</td>
                                <td>Level @entry.Level</td>
                                <td><span class='@(entry.Result == "WIN" ? "win-badge" : "lose-badge")'>@entry.Result</span></td>
                                <td>@entry.Date</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else if (ActiveTab == "settings")
            {
                <h2 class="settings-title">⚙ Settings Panel</h2>
                <div class="settings-card">
                    <div class="setting-row">
                        <div class="setting-info"><h4>🌑 Dark Theme</h4><p>Classic dark medieval visual landscape.</p></div>
                        <label class="toggle-wrap">
                            <input type="checkbox" checked="@IsDarkStyle" @onchange="ToggleDark" />
                            <span class="toggle-slider"></span>
                        </label>
                    </div>
                    <div class="setting-row">
                        <div class="setting-info"><h4>☀️ Light Theme</h4><p>Bright high-contrast design layer.</p></div>
                        <label class="toggle-wrap">
                            <input type="checkbox" checked="@IsLightStyle" @onchange="ToggleLight" />
                            <span class="toggle-slider"></span>
                        </label>
                    </div>
                    <div class="setting-row">
                        <div class="setting-info"><h4>👁 Colorblind Mode</h4><p>Contrast correction properties.</p></div>
                        <label class="toggle-wrap">
                            <input type="checkbox" checked="@IsColorblindStyle" @onchange="ToggleColorblind" />
                            <span class="toggle-slider"></span>
                        </label>
                    </div>
                </div>
            }
        }

        @* ------------------ REALTIME ARENA ENGINE ------------------ *@
        else if (CurrentView == ViewState.GameScreen)
        {
            var config = GameEngineService.Levels[Engine.State!.Level];
            
            bool isKnightAttacking = LiveHitTexts.Any(h => h.IsEnemy == true && h.Text.Contains("⚔"));
            bool isEnemyAttacking = LiveHitTexts.Any(h => h.IsEnemy == false);
            bool isKnightHit = LiveHitTexts.Any(h => h.IsEnemy == false && h.Text.Contains("💥"));
            bool isEnemyHit = LiveHitTexts.Any(h => h.IsEnemy == true && h.Text.Contains("⚔"));
            
            <div class="game-wrapper">
                <div class="game-bg">
                    <div class="sky"></div><div class="ground"></div><div class="moon"></div>
                    <div class="torch" style="position:absolute;bottom:37%;left:15%;font-size:1.8rem">🔥</div>
                    <div class="torch" style="position:absolute;bottom:37%;right:15%;font-size:1.8rem">🔥</div>
                </div>

                @* REAL-TIME HUD STATUS BAR *@
                <div class="game-hud">
                    <div class="hud-health">
                        <div class="hud-health-label"><span>🛡️ KNIGHT</span><span>@Engine.State.KnightHP / @Engine.State.KnightMaxHP</span></div>
                        <div class="hp-bar"><div class="hp-fill hp-fill-knight" style="width:@(CalculateHpPercentage(Engine.State.KnightHP, Engine.State.KnightMaxHP))%; background: @GetHpBarColor(Engine.State.KnightHP, Engine.State.KnightMaxHP)"></div></div>
                    </div>
                    <div class="hud-center">
                        <div class="hud-level-badge">@config.Badge</div>
                        <div class="hud-score">⚔ @Engine.State.Score PTS</div>
                    </div>
                    <div class="hud-health" style="align-items:flex-end">
                        <div class="hud-health-label"><span>@Engine.State.EnemyHP / @Engine.State.EnemyMaxHP</span><span>@config.EnemyLabel</span></div>
                        <div class="hp-bar"><div class="hp-fill hp-fill-enemy" style="width:@(CalculateHpPercentage(Engine.State.EnemyHP, Engine.State.EnemyMaxHP))%"></div></div>
                    </div>
                </div>

                @* GAMEPLAY RUNTIME INTERACTIVE ARENA *@
                <div class="game-arena" id="gameArena" style="position: relative; overflow: hidden; min-height: 280px; display: flex; align-items: flex-end; justify-content: space-between; padding: 0 80px;">
                    
                    @* DYNAMIC HIT-TEXT ANCHORS (FIX: Added .ToList() to prevent Thread Crash Exception) *@
                    @foreach (var hit in LiveHitTexts.ToList())
                    {
                        <div class="hit-text" style="color:@hit.Color; font-size:1.8rem; font-weight:black; position:absolute; top:@(hit.Top)%; @(hit.IsEnemy ? "right:30%;" : "left:30%;") text-shadow:0 0 15px #000; z-index: 10; animation: floatUp 0.6s ease-out;">
                            @hit.Text
                        </div>
                    }

                    @* FIGHTER: KNIGHT *@
                    <div class="fighter @(isKnightAttacking ? "knight-dash-attack" : "") @(isKnightHit ? "hit-shake" : "")" 
                         style="transform: translateX(@(Engine.KnightMarginLeft)px); z-index: 2; margin-bottom: 30px;">
                        <div class="fighter-sprite">
                            <svg width="140" height="160" viewBox="0 0 140 160" xmlns="http://www.w3.org/2000/svg">
                                <defs>
                                    <linearGradient id="armorGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                                        <stop offset="0%" stop-color="#9aa8b8" />
                                        <stop offset="50%" stop-color="#5a6675" />
                                        <stop offset="100%" stop-color="#343d46" />
                                    </linearGradient>
                                    <linearGradient id="goldGrad" x1="0%" y1="0%" x2="0%" y2="100%">
                                        <stop offset="0%" stop-color="#FFE066" />
                                        <stop offset="100%" stop-color="#CC8800" />
                                    </linearGradient>
                                    <linearGradient id="bladeGrad" x1="0%" y1="0%" x2="100%" y2="0%">
                                        <stop offset="0%" stop-color="#FFFFFF" />
                                        <stop offset="35%" stop-color="#DCE4EC" />
                                        <stop offset="100%" stop-color="#A5B1C2" />
                                    </linearGradient>
                                </defs>
                                <ellipse cx="65" cy="150" rx="40" ry="8" fill="rgba(0,0,0,0.45)" />

                                <rect x="44" y="110" width="16" height="35" fill="url(#armorGrad)" stroke="#1E232A" stroke-width="3" rx="4" />
                                <rect x="70" y="110" width="16" height="35" fill="url(#armorGrad)" stroke="#1E232A" stroke-width="3" rx="4" />
                                <path d="M38 138 C38 132, 44 132, 44 132 H60 V146 H38 Z" fill="#2F3640" stroke="#1E232A" stroke-width="2" />
                                <path d="M70 132 H86 C86 132, 92 132, 92 138 V146 H70 Z" fill="#2F3640" stroke="#1E232A" stroke-width="2" />

                                <path d="M32 60 H98 L90 115 H40 Z" fill="url(#armorGrad)" stroke="#1E232A" stroke-width="3.5" />
                                <path d="M40 60 L65 95 L90 60" fill="none" stroke="url(#goldGrad)" stroke-width="4" stroke-linecap="round" />
                                <rect x="48" y="100" width="34" height="10" fill="url(#goldGrad)" stroke="#1E232A" stroke-width="2" rx="2" />

                                <circle cx="65" cy="38" r="24" fill="url(#armorGrad)" stroke="#1E232A" stroke-width="3.5" />
                                <path d="M49 24 H81 V36 H49 Z" fill="#2F3640" stroke="#1E232A" stroke-width="2" />
                                <path d="M61 14 L65 -2 L69 14 Z" fill="#FF4757" />
                                <rect x="52" y="30" width="10" height="4" rx="1" fill="#00D2D3" filter="drop-shadow(0 0 4px #00D2D3)" />
                                <rect x="68" y="30" width="10" height="4" rx="1" fill="#00D2D3" filter="drop-shadow(0 0 4px #00D2D3)" />

                                @{
                                    string knightSwordAngle = isKnightAttacking ? "75" : (Engine.State.Blocking ? "-30" : "15");
                                }
                                <g transform="translate(100, 85) rotate(@knightSwordAngle)" style="transition: transform 0.08s cubic-bezier(0.175, 0.885, 0.32, 1.275); transform-origin: 10px 20px;">
                                    <rect x="6" y="15" width="8" height="28" fill="#57606F" rx="2" stroke="#1E232A" stroke-width="2" />
                                    <rect x="-12" y="12" width="44" height="7" fill="url(#goldGrad)" stroke="#1E232A" stroke-width="2" rx="2" />
                                    <path d="M3 12 L6 -85 L10 -105 L14 -85 L17 12 Z" fill="url(#bladeGrad)" stroke="#1E232A" stroke-width="2.5" />
                                </g>

                                <g transform="translate(@(Engine.State.Blocking ? "55" : "22"), 68)" style="transition: transform 0.08s ease-out;">
                                    <path d="M-22 -28 H22 V5 C22 28, 0 52, 0 58 C0 52, -22 28, -22 5 Z" fill="#B33939" stroke="#1E232A" stroke-width="3.5" />
                                    <path d="M-22 5 H22 M0 -28 V58" stroke="url(#goldGrad)" stroke-width="5" stroke-linecap="round" />
                                </g>
                            </svg>
                        </div>
                        <div class="fighter-label" style="text-align:center; font-weight:bold; color:#fff; margin-top:5px;">KNIGHT</div>
                    </div>

                    @* FIGHTER: ENEMY (FIX: Anchored with absolute position and binded to AI Movement translation) *@
                    @{
                        int enemyTranslation = -Engine.EnemyMarginRight;
                        if (isEnemyAttacking && !Engine.State.Over && !Engine.State.Paused)
                        {
                            enemyTranslation -= 45; 
                        }
                    }
                    <div class="fighter @(isEnemyAttacking ? "enemy-dash-attack" : "") @(isEnemyHit ? "hit-shake" : "")" 
                         style="transform: translateX(@(enemyTranslation)px); position: absolute; right: 80px; z-index: 2; margin-bottom: 30px;">
                        <div class="fighter-sprite">
                            @if (config.Enemy == "skeleton")
                            {
                                <svg width="140" height="160" viewBox="0 0 140 160" xmlns="http://www.w3.org/2000/svg">
                                    <defs>
                                        <linearGradient id="boneGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                                            <stop offset="0%" stop-color="#FFFFFF" />
                                            <stop offset="60%" stop-color="#E0E4EE" />
                                            <stop offset="100%" stop-color="#A5B1C2" />
                                        </linearGradient>
                                        <linearGradient id="ironAxe" x1="0%" y1="0%" x2="100%" y2="100%">
                                            <stop offset="0%" stop-color="#57606F" />
                                            <stop offset="100%" stop-color="#2F3640" />
                                        </linearGradient>
                                    </defs>
                                    <ellipse cx="70" cy="150" rx="35" ry="7" fill="rgba(0,0,0,0.5)" />

                                    @* Legs *@
                                    <path d="M52 105 L48 146 H56 L58 105 Z" fill="url(#boneGrad)" stroke="#2C3A47" stroke-width="2.5" />
                                    <path d="M82 105 L84 146 H92 L88 105 Z" fill="url(#boneGrad)" stroke="#2C3A47" stroke-width="2.5" />

                                    @* Ribcage & Spine Body *@
                                    <line x1="70" y1="55" x2="70" y2="108" stroke="url(#boneGrad)" stroke-width="8" stroke-linecap="round" />
                                    <path d="M50 66 C50 60, 90 60, 90 66" fill="none" stroke="url(#boneGrad)" stroke-width="5" stroke-linecap="round" />
                                    <path d="M46 78 C46 72, 94 72, 94 78" fill="none" stroke="url(#boneGrad)" stroke-width="5" stroke-linecap="round" />
                                    <path d="M48 90 C48 84, 92 84, 92 90" fill="none" stroke="url(#boneGrad)" stroke-width="5" stroke-linecap="round" />
                                    <path d="M52 104 C52 96, 88 96, 88 104 Z" fill="url(#boneGrad)" stroke="#2C3A47" stroke-width="2.5" />

                                    @* Head Skull *@
                                    <circle cx="70" cy="32" r="18" fill="url(#boneGrad)" stroke="#2C3A47" stroke-width="3" />
                                    <rect x="61" y="44" width="18" height="10" rx="3" fill="url(#boneGrad)" stroke="#2C3A47" stroke-width="2" />
                                    <ellipse cx="63" cy="32" rx="4" ry="5" fill="#1E232A" />
                                    <ellipse cx="77" cy="32" rx="4" ry="5" fill="#1E232A" />
                                    <circle cx="63" cy="32" r="2" fill="#FF4757" filter="drop-shadow(0 0 3px #FF2E93)" />
                                    <circle cx="77" cy="32" r="2" fill="#FF4757" filter="drop-shadow(0 0 3px #FF2E93)" />

                                    @* Dynamic Weapon Movement Fix *@
                                    @{
                                        string skeletonAxeAngle = isEnemyAttacking ? "-80" : "-15";
                                    }
                                    <g transform="translate(42, 70) rotate(@skeletonAxeAngle)" style="transition: transform 0.08s ease-in-out; transform-origin: 5px 15px;">
                                        <rect x="2" y="-60" width="6" height="110" fill="#747D8C" rx="2" stroke="#2C3A47" stroke-width="2" />
                                        <path d="M4 -50 C-36 -58, -40 -15, 4 5 Z" fill="url(#ironAxe)" stroke="#1E232A" stroke-width="2.5" />
                                        <rect x="0" y="-52" width="10" height="8" fill="url(#goldGrad)" />
                                    </g>
                                </svg>
                            }
                            else if (config.Enemy == "warrior")
                            {
                                <svg width="140" height="160" viewBox="0 0 140 160" xmlns="http://www.w3.org/2000/svg">
                                    <ellipse cx="70" cy="150" rx="42" ry="8" fill="rgba(0,0,0,0.55)" />
                                    <rect x="46" y="105" width="14" height="38" fill="#2F3542" stroke="#1E232A" stroke-width="2.5" />
                                    <rect x="80" y="105" width="14" height="38" fill="#2F3542" stroke="#1E232A" stroke-width="2.5" />
                                    
                                    <path d="M34 52 H102 L92 110 H44 Z" fill="#2F3542" stroke="#FF6B6B" stroke-width="3" />
                                    <circle cx="70" cy="30" r="18" fill="#747D8C" stroke="#1E232A" stroke-width="3" />
                                    <path d="M52 24 C52 8, 88 8, 88 24 Z" fill="#2f3640" stroke="#1E232A" stroke-width="2" />
                                    
                                    <circle cx="62" cy="28" r="3" fill="#FF0000" filter="drop-shadow(0 0 4px #FF0000)" />
                                    <circle cx="78" cy="28" r="3" fill="#FF0000" filter="drop-shadow(0 0 4px #FF0000)" />

                                    @{
                                        string warriorWeaponAngle = isEnemyAttacking ? "-70" : "-10";
                                    }
                                    <g transform="translate(32, 70) rotate(@warriorWeaponAngle)" style="transition: transform 0.08s ease; transform-origin: 3px 15px;">
                                        <rect x="0" y="-70" width="6" height="135" fill="#57606F" stroke="#1E232A" stroke-width="2" />
                                        <path d="M6 -55 L36 -68 L32 -22 L6 -30 Z" fill="#747D8C" stroke="#1E232A" stroke-width="2.5" />
                                    </g>
                                </svg>
                            }
                            else if (config.Enemy == "dragon")
                            {
                                <svg width="190" height="190" viewBox="0 0 190 190" xmlns="http://www.w3.org/2000/svg">
                                    <ellipse cx="95" cy="170" rx="60" ry="12" fill="rgba(0,0,0,0.6)" />
                                    <path d="M85 85 C35 25, 5 55, 0 115 C20 105, 50 105, 85 100 Z" fill="#781D1D" stroke="#3A0505" stroke-width="2.5" />
                                    <path d="M105 85 C155 25, 185 55, 190 115 C170 105, 140 105, 105 100 Z" fill="#781D1D" stroke="#3A0505" stroke-width="2.5" />
                                    <ellipse cx="95" cy="120" rx="34" ry="45" fill="#A82323" stroke="#4A0E0E" stroke-width="4" />
                                    
                                    <g transform="translate(105,40)">
                                        <path d="M-12 -6 L25 -25 L45 2 L25 18 L-12 12 Z" fill="#FF2E2E" stroke="#4A0E0E" stroke-width="2" />
                                        <circle cx="10" cy="-2" r="5" fill="#FFEE58" filter="drop-shadow(0 0 5px #FFA000)" />
                                    </g>
                                </svg>
                            }

                            @* FIREBALL PROJECTILE RUNTIME *@
                            @if (Engine.IsProjectileActive)
                            {
                                <div class="sk-fire" style="position:absolute; left: -@(Engine.ProjectilePosition * 1.8)px; bottom: 70px; transition: left 0.04s linear; font-size: 2.5rem; text-shadow: 0 0 25px #FF3D00; z-index: 5;">🔥</div>
                            }
                        </div>
                        <div class="fighter-label" style="text-align:center; font-weight:bold; color:#fff; margin-top:5px;">@config.Label.ToUpper()</div>
                    </div>

                    @* STATISTICS INTERFACE ENGINE PANELS *@
                    <div class="stats-panels" style="z-index: 4; display:none;">
                        <div class="stat-panel">
                            <div class="sp-title">Knight Properties</div>
                            <div class="sp-row"><span>hp</span><span>@Engine.State.KnightHP</span></div>
                        </div>
                    </div>

                    @* LIVE COMBAT RADAR LOGS *@
                    <div class="combat-log" style="position: absolute; bottom: 10px; left: 50%; transform: translateX(-50%); text-align: center; background: rgba(0,0,0,0.6); padding: 5px 20px; rx: 5px; border-radius: 4px; z-index: 4;">
                        @foreach (var log in Engine.CombatLog.Take(1))
                        {
                            <p class="log-entry" style="margin:0; color:#fff; font-size:1.1rem; font-weight:bold;">@log</p>
                        }
                    </div>

                    @* FULL SCREEN ENGINE FLASH ELEMENT *@
                    <div class="damage-flash @(ShouldFlashScreen ? "active-flash" : "")" style="z-index: 8;"></div>

                    @* ENGINE DIALOG POPUPS / OVERLAYS *@
                    @if (Engine.State.Over || Engine.State.Paused)
                    {
                        <div class="game-overlay show" style="z-index: 20;">
                            <div class="overlay-title">@OverlayTitle</div>
                            <div class="overlay-sub">@OverlaySubtitle</div>
                            <div class="overlay-btns">
                                @if (Engine.State.Paused && !Engine.State.Over)
                                {
                                    <button class="overlay-btn ob-gold" @onclick="Engine.TogglePause">▶ RESUME</button>
                                }
                                @if (Engine.State.Over && Engine.State.Level < 3 && IsCurrentGameVictory)
                                {
                                    <button class="overlay-btn ob-green" @onclick="() => StartBattle(Engine.State.Level + 1)">▶ NEXT LEVEL</button>
                                }
                                @if (Engine.State.Over)
                                {
                                    <button class="overlay-btn ob-gold" @onclick="() => StartBattle(Engine.State.Level)">↺ REPLAY</button>
                                }
                                <button class="overlay-btn ob-red" @onclick="ExitGameToCitadel">✕ EXIT</button>
                            </div>
                        </div>
                    }
                </div>

                @* MECHANICAL RUNTIME INTERACTIVE BUTTON CONTROLS *@
                <div class="game-controls" style="margin-top: 15px; display: flex; justify-content: center; gap: 10px;">
                    <button class="ctrl-btn" @onclick="() => Engine.MoveKnight(-1)">◀ BACKWARD</button>
                    <button class="ctrl-btn" @onmousedown="Engine.StartBlock" @onmouseup="Engine.StopBlock" @onmouseleave="Engine.StopBlock">🛡️ BLOCK SHIELD</button>
                    <button class="ctrl-btn ctrl-btn-attack" style="background:#ff4757; color:#fff; font-weight:bold;" @onclick="Engine.KnightAttack">⚔ ATTACK</button>
                    <button class="ctrl-btn" @onclick="() => Engine.MoveKnight(1)">FORWARD ▶</button>
                    <button class="ctrl-btn" @onclick="Engine.TogglePause">⏸ PAUSE</button>
                </div>
            </div>
        }
    </main>
</div>

@code {
    private enum ViewState { Auth, MainApp, GameScreen }
    private ViewState CurrentView { get; set; } = ViewState.Auth;
    private string ActiveTab { get; set; } = "home";
    private bool IsLoginTab { get; set; } = true;

    // Custom Themes Bound Properties
    private bool IsDarkStyle { get; set; } = true;
    private bool IsLightStyle { get; set; } = false;
    private bool IsColorblindStyle { get; set; } = false;

    // Input Element Binding Targets
    private string AuthUsername { get; set; } = string.Empty;
    private string AuthEmail { get; set; } = string.Empty;
    private string AuthPassword { get; set; } = string.Empty;
    private string AuthErrorMessage { get; set; } = string.Empty;

    private User? CurrentUser { get; set; }
    private List<MatchHistory> MatchHistories { get; set; } = new();
    private List<NotificationItem> Notifications { get; set; } = new();
    private List<HitTextInstance> LiveHitTexts { get; set; } = new();

    private bool ShouldFlashScreen { get; set; } = false;
    private bool IsCurrentGameVictory { get; set; } = false;

    private int warriorWeaponAngle { get; set; } = 0;

    // TEMPORARY IN-MEMORY DB SIMULATION
    private static List<User> InMemoryUsers = new List<User>();
    private static List<MatchHistory> InMemoryMatches = new List<MatchHistory>();

    private string UserInitials => CurrentUser != null && CurrentUser.Username.Length >= 2
        ? CurrentUser.Username[..2].ToUpper() : "??";

    private bool IsAppScreenActive => CurrentView == ViewState.MainApp;

    private string OverlayTitle => Engine.State!.Paused && !Engine.State.Over ? "⏸ PAUSED"
        : (IsCurrentGameVictory ? "⚔ VICTORY!" : "💀 DEFEATED!");

    private string OverlaySubtitle => Engine.State!.Paused && !Engine.State.Over ? "Take a breath, Knight"
        : (IsCurrentGameVictory ? $"You conquered the trial! Score: {Engine.State.Score} pts"
                                : "The enemy domain was too treacherous...");

    protected override void OnInitialized()
    {
        Engine.OnStateChanged += RefreshUI;
        Engine.OnGameEnded += HandleGameCompletion;
        Engine.OnScreenFlash += TriggerFlashEffect;
        Engine.OnHitTextCreated += AddHitTextElement;
    }

    private void RefreshUI() => InvokeAsync(StateHasChanged);

    private void SetTab(string tabName)
    {
        ActiveTab = tabName;
        if (tabName == "profile") LoadUserChronicles();
    }

    private void HandleLogin()
    {
        string encodedPass = Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(AuthPassword));
        
        var matchedUser = InMemoryUsers.FirstOrDefault(u => u.Username.ToLower() == AuthUsername.ToLower()
            && u.PasswordHash == encodedPass);

        if (matchedUser != null)
        {
            CurrentUser = matchedUser;
            CurrentUser.LastLogin = DateTime.Now.ToString("g");
            TransitionToMainApp();
        }
        else
        {
            AuthErrorMessage = "Invalid credentials standard challenge failed.";
        }
    }

    private void HandleRegister()
    {
        if (string.IsNullOrEmpty(AuthUsername) || string.IsNullOrEmpty(AuthPassword))
        {
            AuthErrorMessage = "Credentials cannot be blank.";
            return;
        }

        string encodedPass = Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(AuthPassword));

        if (InMemoryUsers.Any(u => u.Username.ToLower() == AuthUsername.ToLower()))
        {
            AuthErrorMessage = "Username already verified in another house.";
            return;
        }

        var newUser = new User
        {
            Username = AuthUsername,
            Email = AuthEmail,
            PasswordHash = encodedPass
        };

        InMemoryUsers.Add(newUser);
        CurrentUser = newUser;
        TransitionToMainApp();
    }

    private void TransitionToMainApp()
    {
        CurrentView = ViewState.MainApp;
        ActiveTab = "home";
        _ = TriggerNotification($"Welcome to the Citadel, {CurrentUser?.Username}!", "info");
    }

    private void LoadUserChronicles()
    {
        if (CurrentUser != null)
        {
            MatchHistories = InMemoryMatches
                .Where(m => m.UserId == CurrentUser.Id)
                .OrderByDescending(m => m.Id)
                .Take(15)
                .ToList();
        }
    }

    private void StartBattle(int level)
    {
        CurrentView = ViewState.GameScreen;
        Engine.StartGame(level);
    }

    private void HandleGameCompletion(bool won)
    {
        IsCurrentGameVictory = won;
        if (CurrentUser != null && Engine.State != null)
        {
            if (won)
            {
                CurrentUser.Wins++;
                CurrentUser.Streak++;
                if (CurrentUser.Streak > CurrentUser.BestStreak) CurrentUser.BestStreak = CurrentUser.Streak;
                if (Engine.State.Level == 3) CurrentUser.DragonKills++;
            }
            else
            {
                CurrentUser.Losses++;
                CurrentUser.Streak = 0;
            }

            var record = new MatchHistory
            {
                UserId = CurrentUser.Id,
                Level = Engine.State.Level,
                Enemy = GameEngineService.Levels[Engine.State.Level].Label,
                Result = won ? "WIN" : "LOSE"
            };

            InMemoryMatches.Add(record);
        }
        RefreshUI();
    }

    private void ExitGameToCitadel()
    {
        Engine.Dispose();
        CurrentView = ViewState.MainApp;
        ActiveTab = "home";
    }

    private int CalculateHpPercentage(int current, int max) => (int)((double)current / max * 100);

    private string GetHpBarColor(int current, int max)
    {
        double pct = (double)current / max * 100;
        if (pct < 25) return "linear-gradient(90deg,#8a0f0f, #e63946)";
        if (pct < 50) return "linear-gradient(90deg,#8a5a00, #fb8500)";
        return "linear-gradient(90deg,#1a7a3a, #2a9d8f)";
    }

    private async void TriggerFlashEffect()
    {
        ShouldFlashScreen = true;
        await InvokeAsync(StateHasChanged);
        await Task.Delay(400);
        ShouldFlashScreen = false;
        await InvokeAsync(StateHasChanged);
    }

    // FIX: Handled List synchronization inside threads using temporary casting safeguards (.ToList())
    private async void AddHitTextElement(string text, string color, bool isEnemy)
    {
        var instance = new HitTextInstance { Text = text, Color = color, IsEnemy = isEnemy, Top = new Random().Next(35, 55) };
        LiveHitTexts.Add(instance);
        await InvokeAsync(StateHasChanged);

        await Task.Delay(1100);
        LiveHitTexts.Remove(instance);
        await InvokeAsync(StateHasChanged);
    }

    private async Task TriggerNotification(string msg, string type)
    {
        var item = new NotificationItem { Message = msg, Type = type };
        Notifications.Add(item);
        await InvokeAsync(StateHasChanged);

        await Task.Delay(3200);
        Notifications.Remove(item);
        await InvokeAsync(StateHasChanged);
    }

    private void ToggleDark() { IsDarkStyle = true; IsLightStyle = false; }
    private void ToggleLight() { IsLightStyle = true; IsDarkStyle = false; }
    private void ToggleColorblind(ChangeEventArgs e) => IsColorblindStyle = (bool)(e.Value ?? false);

    public void LogOut()
    {
        CurrentUser = null;
        CurrentView = ViewState.Auth;
    }

    public void Dispose()
    {
        Engine.OnStateChanged -= RefreshUI;
        Engine.OnGameEnded -= HandleGameCompletion;
        Engine.OnScreenFlash -= TriggerFlashEffect;
        Engine.OnHitTextCreated -= AddHitTextElement;
    }

    private class NotificationItem { public string Message { get; set; } = ""; public string Type { get; set; } = ""; }
    private class HitTextInstance { public string Text { get; set; } = ""; public string Color { get; set; } = ""; public bool IsEnemy { get; set; } public int Top { get; set; } }
}