@page "/"
@using final_pro_c.Models
@using final_pro_c.Services
@* UNCOMMENT THIS WHEN SQL IS READY *@
@* @using IronCrusadeBlazor.Data *@
@inject GameEngineService Engine
@* @inject AppDbContext Db *@
@implements IDisposable
@rendermode InteractiveServer

<style>
    /* Real-time Dynamic Fighter Animations to fix the static look */
    .fighter {
        transition: all 0.15s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }
    .knight-dash-attack {
        animation: knightStrike 0.15s ease-in-out forwards;
    }
    .enemy-dash-attack {
        animation: enemyStrike 0.15s ease-in-out forwards;
    }
    @@keyframes knightStrike {
        0% { transform: scale(1) translateX(0); }
        50% { transform: scale(1.05) translateX(35px) rotate(4deg); }
        100% { transform: scale(1) translateX(0); }
    }
    @@keyframes enemyStrike {
        0% { transform: scale(1) translateX(0); }
        50% { transform: scale(1.05) translateX(-45px) rotate(-6deg); }
        100% { transform: scale(1) translateX(0); }
    }
    .hit-shake {
        animation: hurtShake 0.2s ease-in-out;
    }
    @@keyframes hurtShake {
        0% { transform: translateX(0); }
        25% { transform: translateX(-10px); }
        50% { transform: translateX(10px); }
        75% { transform: translateX(-5px); }
        100% { transform: translateX(0); }
    }
</style>

<div class="app-container @(IsLightStyle ? "light-theme" : "") @(IsColorblindStyle ? "colorblind-theme" : "")">
    
    @* NOTIFICATION SYSTEM *@
    @foreach (var notif in Notifications.ToList())
    {
        <div class="notif notif-@notif.Type">@notif.Message</div>
    }

    @* DRAWER NAVIGATION CONTROLLER *@
    @if (IsAppScreenActive)
    {
        <aside class="drawer">
            <div class="drawer-header">
                <div class="drawer-avatar">@UserInitials</div>
                <div class="drawer-info">
                    <div class="drawer-username">@CurrentUser?.Username</div>
                    <div class="drawer-status">🟢 Online</div>
                </div>
            </div>
            <nav class="drawer-menu">
                <button class="drawer-link @(ActiveTab == "home" ? "active" : "")" @onclick='() => SetTab("home")'>🏰 Citadel Home</button>
                <button class="drawer-link @(ActiveTab == "profile" ? "active" : "")" @onclick='() => SetTab("profile")'>🛡️ Player Profile</button>
                <button class="drawer-link @(ActiveTab == "settings" ? "active" : "")" @onclick='() => SetTab("settings")'>⚙ Settings</button>
                <button class="drawer-link logout-link" @onclick="LogOut">✕ Disconnect</button>
            </nav>
        </aside>
    }

    <main class="main-content">
        @* ------------------ AUTH PAGE ------------------ *@
        @* @if (CurrentView == ViewState.Auth)
        {
            <div class="auth-box">
                <h2 class="auth-title">⚔ BATTLE OF KNIGHT</h2>
                <div class="auth-tabs">
                    <button class="auth-tab @(IsLoginTab ? "active" : "")" @onclick="() => IsLoginTab = true">LOGIN</button>
                    <button class="auth-tab @(!IsLoginTab ? "active" : "")" @onclick="() => IsLoginTab = false">REGISTER</button>
                </div>

                @if (!string.IsNullOrEmpty(AuthErrorMessage))
                {
                    <div class="auth-msg error">@AuthErrorMessage</div>
                }

                @if (IsLoginTab)
                {
                    <div class="auth-form">
                        <input type="text" placeholder="Username" @bind="AuthUsername" class="auth-input" />
                        <input type="password" placeholder="Password" @bind="AuthPassword" class="auth-input" />
                        <button class="auth-btn" @onclick="HandleLogin">ENTER THE REALM</button>
                    </div>
                }
                else
                {
                    <div class="auth-form">
                        <input type="text" placeholder="Choose Username" @bind="AuthUsername" class="auth-input" />
                        <input type="email" placeholder="Your Email" @bind="AuthEmail" class="auth-input" />
                        <input type="password" placeholder="Secure Password" @bind="AuthPassword" class="auth-input" />
                        <button class="auth-btn" @onclick="HandleRegister">CREATE ACCT</button>
                    </div>
                }
            </div>
        } *@
        @* ------------------ AUTH PAGE UI ------------------ *@
@if (CurrentView == ViewState.Auth)
{
    <div class="auth-box">
        <h2 class="auth-title">⚔ BATTLE OF KNIGHT</h2>
        <div class="auth-tabs">
            <button class="auth-tab @(IsLoginTab ? "active" : "")" @onclick="SwitchToLoginTab">LOGIN</button>
            <button class="auth-tab @(!IsLoginTab ? "active" : "")" @onclick="SwitchToRegisterTab">REGISTER</button>
        </div>

        @* Error Notification *@
        @if (!string.IsNullOrEmpty(AuthErrorMessage))
        {
            <div class="auth-msg error" style="color: #ef4444; background: rgba(239, 68, 68, 0.1); padding: 10px; border-radius: 4px; margin-bottom: 15px; font-size: 0.9rem; border: 1px solid rgba(239, 68, 68, 0.2); text-align: center; font-weight: bold;">
                ⚠️ @AuthErrorMessage
            </div>
        }

        @* Success Notification *@
        @if (!string.IsNullOrEmpty(AuthSuccessMessage))
        {
            <div class="auth-msg success" style="color: #22c55e; background: rgba(34, 197, 94, 0.1); padding: 10px; border-radius: 4px; margin-bottom: 15px; font-size: 0.9rem; border: 1px solid rgba(34, 197, 94, 0.2); text-align: center; font-weight: bold;">
                ✅ @AuthSuccessMessage
            </div>
        }

        @if (IsLoginTab)
        {
            <div class="auth-form">
                <input type="text" placeholder="Username" @bind="AuthUsername" class="auth-input" />
                <input type="password" placeholder="Password" @bind="AuthPassword" class="auth-input" />
                <button class="auth-btn" @onclick="HandleLogin">ENTER THE REALM</button>
            </div>
        }
        else
        {
            <div class="auth-form">
                <input type="text" placeholder="Choose Username" @bind="AuthUsername" class="auth-input" />
                <input type="text" placeholder="Your Email (e.g. name@domain.com)" @bind="AuthEmail" class="auth-input" />
                <input type="password" placeholder="Secure Password (Min 8 chars)" @bind="AuthPassword" class="auth-input" />
                <button class="auth-btn" @onclick="HandleRegister">CREATE ACCT</button>
            </div>
        }
    </div>
}

        @* ------------------ MAIN DASHBOARD ------------------ *@
        @if (CurrentView == ViewState.MainApp)
        {
            @if (ActiveTab == "home")
            {
                <div class="welcome-banner">
                    <h1>Welcome, Vanguard @CurrentUser?.Username!</h1>
                    <p>The dark lands await your deployment. Choose a level to begin.</p>
                </div>

                <div class="dashboard-stats">
                    <div class="stat-box"><h3>@CurrentUser?.Wins</h3><p>Victories</p></div>
                    <div class="stat-box"><h3>@CurrentUser?.Losses</h3><p>Defeats</p></div>
                    <div class="stat-box"><h3>@(CurrentUser!.Wins + CurrentUser.Losses)</h3><p>Battles Played</p></div>
                    <div class="stat-box"><h3>@CurrentUser?.BestStreak</h3><p>Best Streak</p></div>
                </div>

                <h2 class="section-heading">⚔ Deploy to Campaign</h2>
                <div class="level-select-grid">
                    <div class="level-card card-easy" @onclick="() => StartBattle(1)">
                        <div class="lvl-num">LVL 1</div><h3>The Skeleton Crypt</h3><p>Difficulty: Easy</p>
                    </div>
                    <div class="level-card card-medium" @onclick="() => StartBattle(2)">
                        <div class="lvl-num">LVL 2</div><h3>The Undead Warrior</h3><p>Difficulty: Medium</p>
                    </div>
                    <div class="level-card card-hard" @onclick="() => StartBattle(3)">
                        <div class="lvl-num">LVL 3</div><h3>The Dragon's Lair</h3><p>Difficulty: Hard</p>
                    </div>
                </div>
            }
            else if (ActiveTab == "profile")
            {
                <div class="profile-card">
                    <div class="profile-avatar-big">@UserInitials</div>
                    <div class="profile-info">
                        <div class="profile-name-big">@CurrentUser?.Username</div>
                        <div class="profile-role">🛡️ Knight of the Crusade</div>
                        <div class="profile-date">Joined: <span>@CurrentUser?.CreatedAt</span></div>
                        <div class="profile-date">Email: <span>@CurrentUser?.Email</span></div>
                    </div>
                </div>

                <div class="match-history-title">⚔ Match History Records</div>
                <table class="match-table">
                    <thead><tr><th>Opponent</th><th>Level</th><th>Result</th><th>Date</th></tr></thead>
                    <tbody>
                        @if (!MatchHistories.Any())
                        {
                            <tr><td colspan="4" style="text-align:center;color:var(--gray)">No chronicles recorded yet.</td></tr>
                        }
                        @foreach (var entry in MatchHistories)
                        {
                            <tr>
                                <td>@entry.Enemy</td>
                                <td>Level @entry.Level</td>
                                <td><span class='@(entry.Result == "WIN" ? "win-badge" : "lose-badge")'>@entry.Result</span></td>
                                <td>@entry.Date</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else if (ActiveTab == "settings")
            {
                <h2 class="settings-title">⚙ Settings Panel</h2>
                <div class="settings-card">
                    <div class="setting-row">
                        <div class="setting-info"><h4>🌑 Dark Theme</h4><p>Classic dark medieval visual landscape.</p></div>
                        <label class="toggle-wrap">
                            <input type="checkbox" checked="@IsDarkStyle" @onchange="ToggleDark" />
                            <span class="toggle-slider"></span>
                        </label>
                    </div>
                    <div class="setting-row">
                        <div class="setting-info"><h4>☀️ Light Theme</h4><p>Bright high-contrast design layer.</p></div>
                        <label class="toggle-wrap">
                            <input type="checkbox" checked="@IsLightStyle" @onchange="ToggleLight" />
                            <span class="toggle-slider"></span>
                        </label>
                    </div>
                    <div class="setting-row">
                        <div class="setting-info"><h4>👁 Colorblind Mode</h4><p>Contrast correction properties.</p></div>
                        <label class="toggle-wrap">
                            <input type="checkbox" checked="@IsColorblindStyle" @onchange="ToggleColorblind" />
                            <span class="toggle-slider"></span>
                        </label>
                    </div>
                </div>
            }
        }
@* ------------------ REALTIME ARENA ENGINE ------------------ *@
else if (CurrentView == ViewState.GameScreen)
{
    var config = GameEngineService.Levels[Engine.State!.Level];
    
    bool isKnightAttacking = LiveHitTexts.Any(h => h.IsEnemy == true && h.Text.Contains("⚔"));
    bool isEnemyAttacking = LiveHitTexts.Any(h => h.IsEnemy == false);
    bool isKnightHit = LiveHitTexts.Any(h => h.IsEnemy == false && h.Text.Contains("💥"));
    bool isEnemyHit = LiveHitTexts.Any(h => h.IsEnemy == true && h.Text.Contains("⚔"));
    
    @* FORCE FULL SCREEN SCREEN WRAPPER: !important ke sath parent container ko kuchalne ke liye *@
    <div class="game-wrapper" style="position: fixed !important; top: 0 !important; left: 0 !important; width: 100vw !important; height: 100vh !important; max-width: 100vw !important; max-height: 100vh !important; background: #0b111e; z-index: 999999 !important; display: flex !important; flex-direction: column !important; overflow: hidden !important; margin: 0 !important; padding: 0 !important; box-sizing: border-box !important;">
        
        @* MAIN VIEWPORT CONTAINER *@
        <div class="game-viewport" style="position: relative !important; flex-grow: 1 !important; width: 100% !important; overflow: hidden !important; display: flex !important; flex-direction: column !important; justify-content: space-between !important;">
            
            @* TOP LEVEL CINEMATIC BATTLE FORTRESS BACKGROUND *@
            <svg viewBox="0 0 1200 400" preserveAspectRatio="xMidYMid slice" style="position: absolute !important; top: 0 !important; left: 0 !important; width: 100% !important; height: 100% !important; pointer-events: none !important; z-index: 1 !important;">
                <defs>
                    @* Sky Gradient *@
                    <linearGradient id="skyGrad" x1="0%" y1="0%" x2="0%" y2="100%">
                        <stop offset="0%" stop-color="#141e30" />
                        <stop offset="60%" stop-color="#243b55" />
                        <stop offset="100%" stop-color="#b06ab3" stop-opacity="0.3" />
                    </linearGradient>
                    @* Mountains/Castle Silhouettes Gradients *@
                    <linearGradient id="fortGradFar" x1="0%" y1="0%" x2="0%" y2="100%">
                        <stop offset="0%" stop-color="#2d3848" stop-opacity="0.7" />
                        <stop offset="100%" stop-color="#111622" />
                    </linearGradient>
                    <linearGradient id="fortGradClose" x1="0%" y1="0%" x2="0%" y2="100%">
                        <stop offset="0%" stop-color="#1d2433" />
                        <stop offset="100%" stop-color="#090d16" />
                    </linearGradient>
                    @* Sun/Moon Eclipse Glow *@
                    <radialGradient id="moonGlow" cx="50%" cy="50%" r="50%">
                        <stop offset="0%" stop-color="#ffe29d" stop-opacity="0.4" />
                        <stop offset="40%" stop-color="#ffb703" stop-opacity="0.1" />
                        <stop offset="100%" stop-color="#141e30" stop-opacity="0" />
                    </radialGradient>
                </defs>

                @* Sky Layers *@
                <rect width="1200" height="400" fill="url(#skyGrad)" />
                <circle cx="600" cy="140" r="180" fill="url(#moonGlow)" />
                <circle cx="600" cy="140" r="45" fill="#ffe29d" opacity="0.8" />

                @* Far Away Mountains & Clouds *@
                <path d="M0 260 L120 210 L280 250 L450 190 L600 240 L820 180 L1020 230 L1200 190 L1200 400 L0 400 Z" fill="#1a2230" opacity="0.5" />

                @* LEFT SIDE CITADEL FORTRESS *@
                <g fill="url(#fortGradFar)">
                    <rect x="60" y="110" width="45" height="150" />
                    <polygon points="55,110 82,70 110,110" />
                    <rect x="150" y="80" width="55" height="180" />
                    <polygon points="145,80 177,35 210,80" />
                    <rect x="100" y="160" width="60" height="100" />
                    <rect x="0" y="180" width="70" height="90" />
                </g>

                @* RIGHT SIDE SEIGE WALLS & DRAGON CORNER *@
                <g fill="url(#fortGradFar)">
                    <rect x="940" y="90" width="50" height="180" />
                    <polygon points="935,90 965,40 1015,90" />
                    <rect x="1040" y="130" width="40" height="140" />
                    <polygon points="1035,130 1060,95 1085,130" />
                    <rect x="980" y="170" width="70" height="100" />
                    <rect x="1070" y="180" width="130" height="90" />
                </g>

                @* CLOSE FRONT GROUND LAYER *@
                <g fill="url(#fortGradClose)">
                    <rect x="220" y="130" width="75" height="170" />
                    <path d="M220 130 H295 L285 110 H230 Z" />
                    <rect x="230" y="90" width="15" height="20" />
                    <rect x="270" y="90" width="15" height="20" />
                    <rect x="850" y="150" width="70" height="150" />
                    <path d="M840 150 L860 130 L910 130 L930 150 Z" />
                    
                    <path d="M0 270 Q300 280, 600 275 T1200 270 L1200 400 L0 400 Z" />
                </g>

                @* Cinematic Battlefield War Dust/Glow Effect *@
                <rect x="0" y="270" width="1200" height="130" fill="rgba(11, 17, 30, 0.4)" />
                <line x1="0" y1="272" x2="1200" y2="272" stroke="rgba(255,183,3,0.15)" stroke-width="2" />
            </svg>

            @* Torches *@
            <div class="torch" style="position:absolute !important; bottom:32% !important; left:12% !important; font-size:2rem !important; filter: drop-shadow(0 0 12px #ff5722) !important; z-index: 2 !important;">🔥</div>
            <div class="torch" style="position:absolute !important; bottom:32% !important; right:12% !important; font-size:2rem !important; filter: drop-shadow(0 0 12px #ff5722) !important; z-index: 2 !important;">🔥</div>

            @* REAL-TIME HUD STATUS BAR *@
            <div class="game-hud" style="position: relative !important; z-index: 3 !important; display: flex !important; justify-content: space-between !important; padding: 25px 40px !important; background: linear-gradient(to bottom, rgba(0,0,0,0.7), rgba(0,0,0,0)) !important; width: 100% !important; box-sizing: border-box !important;">
                <div class="hud-health" style="display: flex; flex-direction: column;">
                    <div class="hud-health-label" style="color:#fff !important; font-weight:bold !important; font-size:1.1rem !important; text-shadow: 2px 2px 4px #000 !important; margin-bottom:6px !important;"><span>🛡️ KNIGHT</span></div>
                    <div class="hp-bar" style="background:#1e293b !important; width:280px !important; height:16px !important; border-radius:4px !important; overflow:hidden !important; border:2px solid #475569 !important; box-shadow: 0 0 10px rgba(0,0,0,0.5) !important;"><div class="hp-fill hp-fill-knight" style="width:@(CalculateHpPercentage(Engine.State.KnightHP, Engine.State.KnightMaxHP))% !important; height:100% !important; background: @GetHpBarColor(Engine.State.KnightHP, Engine.State.KnightMaxHP) !important;"></div></div>
                    <div style="color:#94a3b8 !important; font-size:0.9rem !important; font-weight:bold !important; margin-top:4px !important;">@Engine.State.KnightHP / @Engine.State.KnightMaxHP</div>
                </div>
                <div class="hud-center" style="text-align:center !important; color:#fff !important; align-self: center !important;">
                    <div class="hud-level-badge" style="background:#ffb703 !important; color:#000 !important; padding:4px 14px !important; border-radius:20px !important; font-weight:bold !important; font-size:1rem !important; box-shadow: 0 4px 6px rgba(0,0,0,0.2) !important; display: inline-block;">LVL @Engine.State.Level</div>
                    <div class="hud-score" style="font-weight:bold !important; font-size:1.5rem !important; margin-top:6px !important; text-shadow:0 0 12px #ffb703 !important;">⚔ @Engine.State.Score PTS</div>
                </div>
                <div class="hud-health" style="display: flex; flex-direction: column; align-items: flex-end;">
                    <div class="hud-health-label" style="color:#fff !important; font-weight:bold !important; font-size:1.1rem !important; text-shadow: 2px 2px 4px #000 !important; margin-bottom:6px !important;"><span>@config.EnemyLabel 💀</span></div>
                    <div class="hp-bar" style="background:#1e293b !important; width:280px !important; height:16px !important; border-radius:4px !important; overflow:hidden !important; border:2px solid #475569 !important; box-shadow: 0 0 10px rgba(0,0,0,0.5) !important;"><div class="hp-fill hp-fill-enemy" style="width:@(CalculateHpPercentage(Engine.State.EnemyHP, Engine.State.EnemyMaxHP))% !important; height:100% !important; background:#ef4444 !important;"></div></div>
                    <div style="color:#94a3b8 !important; font-size:0.9rem !important; font-weight:bold !important; margin-top:4px !important;">@Engine.State.EnemyHP / @Engine.State.EnemyMaxHP</div>
                </div>
            </div>

            @* GAMEPLAY RUNTIME INTERACTIVE ARENA *@
            <div class="game-arena" id="gameArena" style="position: relative !important; z-index: 3 !important; overflow: hidden !important; flex-grow: 1 !important; display: flex !important; align-items: flex-end !important; justify-content: space-between !important; padding: 0 10% 40px 10% !important; width: 100% !important; box-sizing: border-box !important;">
                
                @* DYNAMIC HIT-TEXT ANCHORS *@
                @foreach (var hit in LiveHitTexts.ToList())
                {
                    <div class="hit-text" style="color:@hit.Color !important; font-size:2.2rem !important; font-weight:900 !important; position:absolute !important; top:@(hit.Top)% !important; @(hit.IsEnemy ? "right:35%;" : "left:35%;") text-shadow:0 0 15px #000 !important; z-index: 10 !important; animation: floatUp 0.6s ease-out;">
                        @hit.Text
                    </div>
                }

                @* FIGHTER: KNIGHT *@
                <div class="fighter @(isKnightAttacking ? "knight-dash-attack" : "") @(isKnightHit ? "hit-shake" : "")" 
                     style="transform: translateX(@(Engine.KnightMarginLeft)px) !important; z-index: 2 !important; margin-bottom: 20px !important;">
                    <div class="fighter-sprite">
                        <svg width="160" height="180" viewBox="0 0 140 160" xmlns="http://www.w3.org/2000/svg">
                            <defs>
                                <linearGradient id="armorGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                                    <stop offset="0%" stop-color="#9aa8b8" />
                                    <stop offset="50%" stop-color="#5a6675" />
                                    <stop offset="100%" stop-color="#343d46" />
                                </linearGradient>
                                <linearGradient id="goldGrad" x1="0%" y1="0%" x2="0%" y2="100%">
                                    <stop offset="0%" stop-color="#FFE066" />
                                    <stop offset="100%" stop-color="#CC8800" />
                                </linearGradient>
                                <linearGradient id="bladeGrad" x1="0%" y1="0%" x2="100%" y2="0%">
                                    <stop offset="0%" stop-color="#FFFFFF" />
                                    <stop offset="35%" stop-color="#DCE4EC" />
                                    <stop offset="100%" stop-color="#A5B1C2" />
                                </linearGradient>
                            </defs>
                            <ellipse cx="65" cy="150" rx="40" ry="8" fill="rgba(0,0,0,0.45)" />
                            <rect x="44" y="110" width="16" height="35" fill="url(#armorGrad)" stroke="#1E232A" stroke-width="3" rx="4" />
                            <rect x="70" y="110" width="16" height="35" fill="url(#armorGrad)" stroke="#1E232A" stroke-width="3" rx="4" />
                            <path d="M38 138 C38 132, 44 132, 44 132 H60 V146 H38 Z" fill="#2F3640" stroke="#1E232A" stroke-width="2" />
                            <path d="M70 132 H86 C86 132, 92 132, 92 138 V146 H70 Z" fill="#2F3640" stroke="#1E232A" stroke-width="2" />
                            <path d="M32 60 H98 L90 115 H40 Z" fill="url(#armorGrad)" stroke="#1E232A" stroke-width="3.5" />
                            <path d="M40 60 L65 95 L90 60" fill="none" stroke="url(#goldGrad)" stroke-width="4" stroke-linecap="round" />
                            <rect x="48" y="100" width="34" height="10" fill="url(#goldGrad)" stroke="#1E232A" stroke-width="2" rx="2" />
                            <circle cx="65" cy="38" r="24" fill="url(#armorGrad)" stroke="#1E232A" stroke-width="3.5" />
                            <path d="M49 24 H81 V36 H49 Z" fill="#2F3640" stroke="#1E232A" stroke-width="2" />
                            <path d="M61 14 L65 -2 L69 14 Z" fill="#FF4757" />
                            <rect x="52" y="30" width="10" height="4" rx="1" fill="#00D2D3" filter="drop-shadow(0 0 4px #00D2D3)" />
                            <rect x="68" y="30" width="10" height="4" rx="1" fill="#00D2D3" filter="drop-shadow(0 0 4px #00D2D3)" />
                            @{ string knightSwordAngle = isKnightAttacking ? "75" : (Engine.State.Blocking ? "-30" : "15"); }
                            <g transform="translate(100, 85) rotate(@knightSwordAngle)" style="transition: transform 0.08s cubic-bezier(0.175, 0.885, 0.32, 1.275); transform-origin: 10px 20px;">
                                <rect x="6" y="15" width="8" height="28" fill="#57606F" rx="2" stroke="#1E232A" stroke-width="2" />
                                <rect x="-12" y="12" width="44" height="7" fill="url(#goldGrad)" stroke="#1E232A" stroke-width="2" rx="2" />
                                <path d="M3 12 L6 -85 L10 -105 L14 -85 L17 12 Z" fill="url(#bladeGrad)" stroke="#1E232A" stroke-width="2.5" />
                            </g>
                            <g transform="translate(@(Engine.State.Blocking ? "55" : "22"), 68)" style="transition: transform 0.08s ease-out;">
                                <path d="M-22 -28 H22 V5 C22 28, 0 52, 0 58 C0 52, -22 28, -22 5 Z" fill="#B33939" stroke="#1E232A" stroke-width="3.5" />
                                <path d="M-22 5 H22 M0 -28 V58" stroke="url(#goldGrad)" stroke-width="5" stroke-linecap="round" />
                            </g>
                        </svg>
                    </div>
                    <div class="fighter-label" style="text-align:center !important; font-weight:bold !important; color:#fff !important; margin-top:5px !important; text-shadow: 2px 2px 4px #000 !important; font-size:1.1rem !important;">KNIGHT</div>
                </div>

                @* FIGHTER: ENEMY *@
                @{
                    int enemyTranslation = -Engine.EnemyMarginRight;
                    if (isEnemyAttacking && !Engine.State.Over && !Engine.State.Paused) { enemyTranslation -= 45; }
                }
                <div class="fighter @(isEnemyAttacking ? "enemy-dash-attack" : "") @(isEnemyHit ? "hit-shake" : "")" 
                     style="transform: translateX(@(enemyTranslation)px) !important; position: absolute !important; right: 10% !important; z-index: 2 !important; margin-bottom: 20px !important;">
                    <div class="fighter-sprite">
                        @if (config.Enemy == "skeleton")
                        {
                            <svg width="160" height="180" viewBox="0 0 140 160" xmlns="http://www.w3.org/2000/svg">
                                <defs>
                                    <linearGradient id="boneGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                                        <stop offset="0%" stop-color="#FFFFFF" />
                                        <stop offset="60%" stop-color="#E0E4EE" />
                                        <stop offset="100%" stop-color="#A5B1C2" />
                                    </linearGradient>
                                    <linearGradient id="ironAxe" x1="0%" y1="0%" x2="100%" y2="100%">
                                        <stop offset="0%" stop-color="#57606F" />
                                        <stop offset="100%" stop-color="#2F3640" />
                                    </linearGradient>
                                </defs>
                                <ellipse cx="70" cy="150" rx="35" ry="7" fill="rgba(0,0,0,0.5)" />
                                <path d="M52 105 L48 146 H56 L58 105 Z" fill="url(#boneGrad)" stroke="#2C3A47" stroke-width="2.5" />
                                <path d="M82 105 L84 146 H92 L88 105 Z" fill="url(#boneGrad)" stroke="#2C3A47" stroke-width="2.5" />
                                <line x1="70" y1="55" x2="70" y2="108" stroke="url(#boneGrad)" stroke-width="8" stroke-linecap="round" />
                                <path d="M50 66 C50 60, 90 60, 90 66" fill="none" stroke="url(#boneGrad)" stroke-width="5" stroke-linecap="round" />
                                <path d="M46 78 C46 72, 94 72, 94 78" fill="none" stroke="url(#boneGrad)" stroke-width="5" stroke-linecap="round" />
                                <path d="M48 90 C48 84, 92 84, 92 90" fill="none" stroke="url(#boneGrad)" stroke-width="5" stroke-linecap="round" />
                                <path d="M52 104 C52 96, 88 96, 88 104 Z" fill="url(#boneGrad)" stroke="#2C3A47" stroke-width="2.5" />
