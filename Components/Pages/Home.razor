@page "/"
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Iron Crusade — Knight's Battle</title>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700;900&family=Raleway:wght@300;400;600;700&display=swap" rel="stylesheet">
    <style>
            *{margin:0;padding:0;box-sizing:border-box}
            :root{
              --gold:#f0c040;--gold2:#c8960a;--dark:#080810;--dark2:#10101c;--dark3:#1a1a2e;
              --panel:#16213e;--panel2:#1e2a4a;--red:#e63946;--blue:#4361ee;--green:#06d6a0;
              --purple:#7b2fbe;--orange:#fb8500;--white:#f8f9fa;--gray:#adb5bd;
              --hp-green:#2ecc71;--hp-red:#e74c3c;
              --font-main:'Raleway',sans-serif;--font-title:'Cinzel',serif;
            }
            body{font-family:var(--font-main);background:var(--dark);color:var(--white);overflow:hidden;height:100vh;width:100vw;user-select:none}
            .page{position:fixed;top:0;left:0;width:100%;height:100%;display:none;flex-direction:column}
            .page.active{display:flex}
            button{cursor:pointer;font-family:var(--font-main)}

            /* ======================================
               LANDING PAGE
            ====================================== */
            #pg-landing{background:radial-gradient(ellipse at center,#1a0a2e 0%,#080810 70%);align-items:center;justify-content:center;overflow:hidden}
            .lnd-stars{position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none}
            .lnd-star{position:absolute;background:#fff;border-radius:50%;animation:twinkle 3s infinite alternate}
            @@keyframes twinkle{0%{opacity:.15;transform:scale(1)}100%{opacity:1;transform:scale(1.4)}}
            .lnd-content{z-index:2;text-align:center;display:flex;flex-direction:column;align-items:center;gap:0.5rem}
            .lnd-title{font-family:var(--font-title);font-size:clamp(2.5rem,6vw,5.5rem);font-weight:900;color:var(--gold);letter-spacing:4px;line-height:1;animation:titleGlow 3s ease-in-out infinite}
             @@keyframes titleGlow{0%,100%{text-shadow:0 0 30px rgba(240,192,64,.6),0 0 60px rgba(240,192,64,.3)}50%{text-shadow:0 0 60px rgba(240,192,64,1),0 0 120px rgba(240,192,64,.5),0 0 200px rgba(240,192,64,.2)}}
            .lnd-sub{font-family:var(--font-title);font-size:1rem;letter-spacing:10px;color:var(--gray);text-transform:uppercase;margin-top:.3rem}
            .lnd-sword{font-size:5rem;animation:swordAnim 4s ease-in-out infinite;display:inline-block;filter:drop-shadow(0 0 20px rgba(240,192,64,.9));margin:.8rem 0}
             @@keyframes swordAnim{0%{transform:rotate(-25deg) scale(1)}30%{transform:rotate(15deg) scale(1.15)}60%{transform:rotate(-10deg) scale(1)}80%{transform:rotate(20deg) scale(1.12)}100%{transform:rotate(-25deg) scale(1)}}
            .lnd-knights{display:flex;gap:3rem;font-size:3rem;margin:.5rem 0;animation:knightFloat 3s ease-in-out infinite}
             @@keyframes knightFloat{0%,100%{transform:translateY(0)}50%{transform:translateY(-12px)}}
            .lnd-btn{font-family:var(--font-title);font-size:1.1rem;padding:.9rem 3.5rem;background:linear-gradient(135deg,#8a6800,var(--gold));color:#1a0a00;border:none;border-radius:4px;letter-spacing:3px;font-weight:700;margin-top:1rem;transition:all .3s;position:relative;overflow:hidden}
            .lnd-btn::after{content:'';position:absolute;top:-50%;left:-50%;width:200%;height:200%;background:linear-gradient(transparent,rgba(255,255,255,.15),transparent);transform:rotate(30deg) translateY(-100%);transition:.5s}
            .lnd-btn:hover{transform:scale(1.07);box-shadow:0 0 40px rgba(240,192,64,.7)}
            .lnd-btn:hover::after{transform:rotate(30deg) translateY(100%)}
            .lnd-particles{position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;overflow:hidden}
            .lnd-particle{position:absolute;border-radius:50%;animation:particleRise linear infinite;opacity:0}
             @@keyframes particleRise{0%{transform:translateY(110vh) scale(0);opacity:0}10%{opacity:.8}90%{opacity:.5}100%{transform:translateY(-10vh) scale(1.5);opacity:0}}
            .lnd-ground{position:absolute;bottom:0;left:0;width:100%;height:120px;background:linear-gradient(transparent,rgba(240,192,64,.05))}

            /* ======================================
               AUTH PAGE
            ====================================== */
            #pg-auth{background:radial-gradient(ellipse at center,#1a0a2e 0%,#080810 70%);align-items:center;justify-content:center}
            .auth-wrap{background:rgba(22,33,62,.95);border:1px solid rgba(240,192,64,.3);border-radius:12px;padding:2.5rem;width:min(420px,90vw);box-shadow:0 0 60px rgba(0,0,0,.8),inset 0 1px 0 rgba(240,192,64,.1)}
            .auth-logo{text-align:center;margin-bottom:1.5rem}
            .auth-logo-icon{font-size:2.5rem;filter:drop-shadow(0 0 10px rgba(240,192,64,.8))}
            .auth-logo-title{font-family:var(--font-title);font-size:1.6rem;color:var(--gold);letter-spacing:2px}
            .auth-tabs{display:flex;border:1px solid rgba(240,192,64,.2);border-radius:6px;margin-bottom:1.5rem;overflow:hidden}
            .auth-tab{flex:1;padding:.7rem;background:transparent;border:none;color:var(--gray);font-family:var(--font-title);font-size:.9rem;letter-spacing:1px;transition:all .3s}
            .auth-tab.active{background:linear-gradient(135deg,rgba(240,192,64,.2),rgba(240,192,64,.1));color:var(--gold)}
            .auth-form{display:flex;flex-direction:column;gap:1rem}
            .auth-form.hidden{display:none}
            .auth-label{font-size:.8rem;color:var(--gray);letter-spacing:1px;text-transform:uppercase;margin-bottom:.3rem}
            .auth-input{width:100%;padding:.75rem 1rem;background:rgba(255,255,255,.05);border:1px solid rgba(240,192,64,.2);border-radius:6px;color:var(--white);font-size:.95rem;font-family:var(--font-main);transition:all .3s}
            .auth-input:focus{outline:none;border-color:var(--gold);background:rgba(240,192,64,.05);box-shadow:0 0 15px rgba(240,192,64,.15)}
            .auth-submit{padding:.85rem;background:linear-gradient(135deg,#8a6800,var(--gold));color:#1a0a00;border:none;border-radius:6px;font-family:var(--font-title);font-size:1rem;letter-spacing:2px;font-weight:700;transition:all .3s;margin-top:.5rem}
            .auth-submit:hover{transform:translateY(-2px);box-shadow:0 8px 25px rgba(240,192,64,.4)}
            .auth-msg{text-align:center;font-size:.85rem;padding:.5rem;border-radius:6px;margin-top:.5rem}
            .auth-msg.error{background:rgba(230,57,70,.15);color:var(--red);border:1px solid rgba(230,57,70,.3)}
            .auth-msg.success{background:rgba(6,214,160,.15);color:var(--green);border:1px solid rgba(6,214,160,.3)}

            /* ======================================
               MAIN APP (Drawer + Content)
            ====================================== */
            #pg-main{background:var(--dark);flex-direction:row;overflow:hidden}
            .drawer{width:240px;background:linear-gradient(180deg,#12123a 0%,#0a0a20 100%);border-right:1px solid rgba(240,192,64,.15);display:flex;flex-direction:column;padding:1.5rem 0;flex-shrink:0;transition:width .3s}
            .drawer-header{padding:0 1.2rem 1.5rem;border-bottom:1px solid rgba(240,192,64,.1)}
            .drawer-game-title{font-family:var(--font-title);font-size:1rem;color:var(--gold);letter-spacing:2px}
            .drawer-user{display:flex;align-items:center;gap:.7rem;margin-top:.8rem}
            .drawer-avatar{width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,var(--gold2),var(--gold));display:flex;align-items:center;justify-content:center;font-family:var(--font-title);font-weight:700;color:#1a0a00;font-size:.9rem;flex-shrink:0}
            .drawer-username{font-size:.85rem;color:var(--gray)}
            .drawer-nav{flex:1;padding:.8rem 0;display:flex;flex-direction:column;gap:.2rem}
            .drawer-link{display:flex;align-items:center;gap:.8rem;padding:.7rem 1.2rem;color:var(--gray);font-size:.9rem;transition:all .3s;border-left:3px solid transparent;cursor:pointer;background:none;border-top:none;border-right:none;border-bottom:none;width:100%;text-align:left;letter-spacing:.5px}
            .drawer-link:hover{color:var(--white);background:rgba(240,192,64,.07);border-left-color:rgba(240,192,64,.4)}
            .drawer-link.active{color:var(--gold);background:rgba(240,192,64,.1);border-left-color:var(--gold)}
            .drawer-link span:first-child{font-size:1.1rem;width:22px;text-align:center}
            .drawer-bottom{padding:1rem 1.2rem;border-top:1px solid rgba(240,192,64,.1)}
            .drawer-logout{display:flex;align-items:center;gap:.8rem;padding:.7rem 1rem;color:var(--red);font-size:.9rem;background:rgba(230,57,70,.08);border:1px solid rgba(230,57,70,.2);border-radius:6px;width:100%;cursor:pointer;transition:all .3s;font-family:var(--font-main)}
            .drawer-logout:hover{background:rgba(230,57,70,.15);border-color:rgba(230,57,70,.5)}
            .main-content{flex:1;overflow-y:auto;overflow-x:hidden;display:flex;flex-direction:column}

            /* ======================================
               SECTION: HOME (Level Cards)
            ====================================== */
            #sec-home{padding:2.5rem;display:flex;flex-direction:column;gap:2.5rem}
            .home-hero{text-align:center;padding-bottom:1.5rem;border-bottom:1px solid rgba(240,192,64,.1)}
            .home-hero-title{font-family:var(--font-title);font-size:2.2rem;color:var(--gold);letter-spacing:2px}
            .home-hero-sub{color:var(--gray);margin-top:.4rem;font-size:.95rem}
            .home-stats-row{display:flex;gap:1rem;justify-content:center;margin-top:1rem;flex-wrap:wrap}
            .home-stat{background:rgba(22,33,62,.8);border:1px solid rgba(240,192,64,.15);border-radius:8px;padding:.7rem 1.5rem;text-align:center;min-width:90px}
            .home-stat-val{font-family:var(--font-title);font-size:1.4rem;color:var(--gold)}
            .home-stat-lbl{font-size:.7rem;color:var(--gray);letter-spacing:1px;text-transform:uppercase;margin-top:.2rem}
            .levels-title{font-family:var(--font-title);font-size:1.3rem;color:var(--white);letter-spacing:2px;text-align:center}
            .levels-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1.5rem}
            .level-card{background:linear-gradient(135deg,rgba(22,33,62,.9),rgba(16,16,30,.95));border-radius:12px;overflow:hidden;border:1px solid rgba(255,255,255,.08);transition:all .35s;position:relative;cursor:default}
            .level-card:hover{transform:translateY(-6px);box-shadow:0 20px 60px rgba(0,0,0,.5)}
            .lc-banner{padding:1.5rem;display:flex;align-items:center;gap:1rem;position:relative;overflow:hidden}
            .lc-banner::before{content:'';position:absolute;inset:0;opacity:.15}
            .lc-easy .lc-banner::before{background:linear-gradient(135deg,var(--green),transparent)}
            .lc-medium .lc-banner::before{background:linear-gradient(135deg,var(--orange),transparent)}
            .lc-hard .lc-banner::before{background:linear-gradient(135deg,var(--red),transparent)}
            .lc-icon{font-size:2.5rem;filter:drop-shadow(0 0 12px currentColor);flex-shrink:0}
            .lc-easy .lc-icon{filter:drop-shadow(0 0 12px var(--green))}
            .lc-medium .lc-icon{filter:drop-shadow(0 0 12px var(--orange))}
            .lc-hard .lc-icon{filter:drop-shadow(0 0 12px var(--red))}
            .lc-info{}
            .lc-level-tag{font-size:.7rem;letter-spacing:2px;text-transform:uppercase;font-weight:600;margin-bottom:.3rem}
            .lc-easy .lc-level-tag{color:var(--green)}
            .lc-medium .lc-level-tag{color:var(--orange)}
            .lc-hard .lc-level-tag{color:var(--red)}
            .lc-name{font-family:var(--font-title);font-size:1.3rem;color:var(--white);letter-spacing:1px}
            .lc-body{padding:1rem 1.5rem 1.5rem}
            .lc-desc{font-size:.85rem;color:var(--gray);line-height:1.6;margin-bottom:1rem}
            .lc-features{display:flex;flex-direction:column;gap:.4rem;margin-bottom:1.2rem}
            .lc-feat{display:flex;align-items:center;gap:.5rem;font-size:.8rem;color:var(--gray)}
            .lc-feat::before{content:'▸';color:var(--gold);font-size:.7rem}
            .lc-play-btn{width:100%;padding:.75rem;border:none;border-radius:6px;font-family:var(--font-title);font-size:.95rem;letter-spacing:2px;font-weight:700;cursor:pointer;transition:all .3s;position:relative;overflow:hidden}
            .lc-easy .lc-play-btn{background:linear-gradient(135deg,#057a4f,var(--green));color:#001a0f}
            .lc-medium .lc-play-btn{background:linear-gradient(135deg,#a54d00,var(--orange));color:#1a0800}
            .lc-hard .lc-play-btn{background:linear-gradient(135deg,#8a1520,var(--red));color:#1a0005}
            .lc-play-btn:hover{transform:scale(1.03);filter:brightness(1.15)}
            .lc-badge{position:absolute;top:.8rem;right:.8rem;padding:.25rem .6rem;border-radius:20px;font-size:.65rem;font-weight:700;letter-spacing:1px;text-transform:uppercase}
            .badge-new{background:rgba(67,97,238,.25);color:#8aaff8;border:1px solid rgba(67,97,238,.4)}
            .badge-hot{background:rgba(251,133,0,.2);color:#ffc566;border:1px solid rgba(251,133,0,.4)}

            /* Reviews */
            .reviews-section{padding-top:1rem}
            .reviews-title{font-family:var(--font-title);font-size:1.3rem;color:var(--white);letter-spacing:2px;text-align:center;margin-bottom:1.5rem}
            .reviews-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:1.2rem}
            .review-card{background:rgba(22,33,62,.7);border:1px solid rgba(255,255,255,.07);border-radius:10px;padding:1.2rem}
            .rv-header{display:flex;align-items:center;gap:.8rem;margin-bottom:.8rem}
            .rv-avatar{width:38px;height:38px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.9rem;flex-shrink:0}
            .rv-name{font-weight:600;font-size:.9rem;color:var(--white)}
            .rv-stars{color:var(--gold);font-size:.8rem;margin-top:.1rem}
            .rv-text{font-size:.82rem;color:var(--gray);line-height:1.6}

            /* ======================================
               SECTION: PROFILE
            ====================================== */
            #sec-profile{padding:2.5rem;display:flex;flex-direction:column;gap:2rem}
            .profile-card{background:linear-gradient(135deg,rgba(22,33,62,.9),rgba(16,16,30,.95));border:1px solid rgba(240,192,64,.2);border-radius:12px;padding:2rem;display:flex;align-items:center;gap:2rem;flex-wrap:wrap}
            .profile-avatar-big{width:90px;height:90px;border-radius:50%;background:linear-gradient(135deg,var(--gold2),var(--gold));display:flex;align-items:center;justify-content:center;font-family:var(--font-title);font-size:2.2rem;font-weight:700;color:#1a0a00;border:3px solid rgba(240,192,64,.3);flex-shrink:0}
            .profile-info{flex:1}
            .profile-name-big{font-family:var(--font-title);font-size:1.8rem;color:var(--gold)}
            .profile-role{font-size:.85rem;color:var(--gray);margin-top:.2rem;letter-spacing:1px}
            .profile-date{font-size:.8rem;color:var(--gray);margin-top:.5rem}
            .profile-date span{color:var(--white)}
            .profile-stats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:1rem}
            .pstat{background:rgba(22,33,62,.8);border:1px solid rgba(240,192,64,.12);border-radius:8px;padding:1.2rem;text-align:center}
            .pstat-val{font-family:var(--font-title);font-size:2rem;color:var(--gold)}
            .pstat-lbl{font-size:.72rem;color:var(--gray);letter-spacing:1px;text-transform:uppercase;margin-top:.3rem}
            .match-history-title{font-family:var(--font-title);font-size:1.1rem;color:var(--white);letter-spacing:2px}
            .match-table{width:100%;border-collapse:collapse}
            .match-table th{font-size:.72rem;color:var(--gray);letter-spacing:1px;text-transform:uppercase;padding:.5rem .8rem;text-align:left;border-bottom:1px solid rgba(255,255,255,.07)}
            .match-table td{padding:.65rem .8rem;font-size:.85rem;border-bottom:1px solid rgba(255,255,255,.04);color:var(--gray)}
            .match-table td:first-child{color:var(--white)}
            .win-badge{background:rgba(6,214,160,.15);color:var(--green);border:1px solid rgba(6,214,160,.3);padding:.15rem .6rem;border-radius:20px;font-size:.72rem;font-weight:700}
            .lose-badge{background:rgba(230,57,70,.1);color:var(--red);border:1px solid rgba(230,57,70,.25);padding:.15rem .6rem;border-radius:20px;font-size:.72rem;font-weight:700}

            /* ======================================
               SECTION: SETTINGS
            ====================================== */
            #sec-settings{padding:2.5rem;display:flex;flex-direction:column;gap:1.5rem;max-width:600px}
            .settings-title{font-family:var(--font-title);font-size:1.5rem;color:var(--gold);letter-spacing:2px}
            .settings-card{background:rgba(22,33,62,.8);border:1px solid rgba(240,192,64,.12);border-radius:10px;padding:1.5rem;display:flex;flex-direction:column;gap:1.2rem}
            .setting-row{display:flex;align-items:center;justify-content:space-between;gap:1rem}
            .setting-info h4{font-size:.95rem;color:var(--white);margin-bottom:.2rem}
            .setting-info p{font-size:.78rem;color:var(--gray);line-height:1.4}
            .toggle-wrap{position:relative;width:52px;height:28px;flex-shrink:0}
            .toggle-wrap input{opacity:0;width:0;height:0}
            .toggle-slider{position:absolute;inset:0;background:rgba(255,255,255,.1);border-radius:28px;cursor:pointer;transition:.3s;border:1px solid rgba(255,255,255,.15)}
            .toggle-slider::before{content:'';position:absolute;left:3px;top:3px;width:20px;height:20px;background:var(--gray);border-radius:50%;transition:.3s}
            .toggle-wrap input:checked + .toggle-slider{background:rgba(240,192,64,.3);border-color:var(--gold)}
            .toggle-wrap input:checked + .toggle-slider::before{transform:translateX(24px);background:var(--gold)}

            /* Dark theme overlay */
            body.light-theme{background:#e8e8f0;color:#1a1a2e}
            body.light-theme .drawer{background:linear-gradient(180deg,#d0d0e8,#c0c0d8);border-right-color:rgba(100,80,40,.3)}
            body.light-theme .drawer-game-title{color:#8a6000}
            body.light-theme .drawer-username,.body.light-theme .drawer-link{color:#444}
            body.light-theme #sec-home,body.light-theme #sec-profile,body.light-theme #sec-settings{background:#e8e8f0}
            body.light-theme .lnd-title,.body.light-theme .home-hero-title{color:#8a6000}
            body.colorblind-theme{filter:grayscale(40%) contrast(1.1)}
            body.colorblind-theme .lc-easy .lc-icon{filter:drop-shadow(0 0 12px #0070b0)}
            body.colorblind-theme .lc-medium .lc-icon{filter:drop-shadow(0 0 12px #d4b000)}
            body.colorblind-theme .lc-hard .lc-icon{filter:drop-shadow(0 0 12px #cc0000)}
            body.colorblind-theme .hp-fill-knight{background:#0070b0 !important}
            body.colorblind-theme .hp-fill-enemy{background:#cc0000 !important}

            /* ======================================
               GAME PAGE
            ====================================== */
            #pg-game{background:#000;flex-direction:column;overflow:hidden}
            /* sky/clouds animated bg */
            .game-bg{position:absolute;inset:0;overflow:hidden;z-index:0}
            .sky{position:absolute;top:0;left:0;width:100%;height:65%;background:linear-gradient(180deg,#0a0518 0%,#1a1040 40%,#2a1a60 100%)}
            .ground{position:absolute;bottom:0;left:0;width:100%;height:38%;background:linear-gradient(180deg,#1a1030 0%,#0a0820 100%)}
            .ground::before{content:'';position:absolute;top:0;left:0;width:100%;height:40px;background:linear-gradient(180deg,rgba(60,40,120,.6),transparent)}
            .moon{position:absolute;top:40px;right:120px;width:60px;height:60px;border-radius:50%;background:radial-gradient(circle at 35% 35%,#f0e8c0,#d4c880);box-shadow:0 0 40px rgba(240,232,192,.4),0 0 80px rgba(240,232,192,.15)}
            .star-g{position:absolute;background:#fff;border-radius:50%;animation:stg 3s infinite alternate}
             @@keyframes stg{0%{opacity:.3}100%{opacity:.9}}
            .torch{position:absolute;animation:torchFlicker .3s infinite alternate}
             @@keyframes torchFlicker{0%{filter:drop-shadow(0 0 8px #ff8800) drop-shadow(0 0 20px rgba(255,136,0,.5))}100%{filter:drop-shadow(0 0 15px #ffaa00) drop-shadow(0 0 35px rgba(255,170,0,.6))}}
            /* HUD TOP */
            .game-hud{position:relative;z-index:10;display:flex;align-items:center;justify-content:space-between;padding:.6rem 1.2rem;background:rgba(0,0,0,.7);border-bottom:1px solid rgba(240,192,64,.2);flex-shrink:0}
            .hud-health{display:flex;flex-direction:column;gap:.25rem;min-width:220px}
            .hud-health-label{font-size:.65rem;letter-spacing:2px;text-transform:uppercase;color:var(--gray);display:flex;justify-content:space-between}
            .hp-bar{height:14px;background:rgba(255,255,255,.08);border-radius:7px;overflow:hidden;border:1px solid rgba(255,255,255,.1);position:relative}
            .hp-fill{height:100%;border-radius:7px;transition:width .4s ease;position:relative;overflow:hidden}
            .hp-fill::after{content:'';position:absolute;top:0;left:-100%;width:60%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,.3),transparent);animation:hpShimmer 2s infinite}
             @@keyframes hpShimmer{0%{left:-100%}100%{left:200%}}
            .hp-fill-knight{background:linear-gradient(90deg,#1a7a3a,var(--hp-green))}
            .hp-fill-enemy{background:linear-gradient(90deg,#8a0f0f,var(--hp-red))}
            .hud-center{text-align:center}
            .hud-level-badge{font-family:var(--font-title);font-size:.7rem;letter-spacing:3px;color:var(--gold);text-transform:uppercase;padding:.3rem .8rem;border:1px solid rgba(240,192,64,.3);border-radius:20px;background:rgba(240,192,64,.08)}
            .hud-score{font-family:var(--font-title);font-size:1.3rem;color:var(--white);margin-top:.3rem}
            .hud-right{text-align:right;min-width:220px}
            /* ARENA */
            .game-arena{flex:1;position:relative;display:flex;align-items:flex-end;justify-content:space-around;padding-bottom:80px;overflow:hidden}
            /* FIGHTERS */
            .fighter{position:relative;display:flex;flex-direction:column;align-items:center;gap:0;z-index:5}
            .fighter-sprite{position:relative;line-height:1}
            .fighter-label{font-family:var(--font-title);font-size:.65rem;letter-spacing:2px;color:var(--gray);text-align:center;margin-top:.3rem}
            /* KNIGHT */
            .knight-wrap{position:relative;cursor:default}
            .knight-body{display:flex;flex-direction:column;align-items:center;position:relative}
            .k-head{width:34px;height:38px;background:linear-gradient(180deg,#c0c8d0,#9098a0);border-radius:6px 6px 2px 2px;position:relative;display:flex;align-items:center;justify-content:center;border:2px solid #6878a0}
            .k-head::before{content:'';position:absolute;top:6px;left:4px;width:8px;height:6px;background:rgba(100,160,255,.7);border-radius:2px;box-shadow:12px 0 0 rgba(100,160,255,.7)}
            .k-head::after{content:'';position:absolute;top:-6px;left:-2px;width:38px;height:12px;background:linear-gradient(180deg,#8098b0,#6878a0);border-radius:4px;border:1px solid #4858a0}
            .k-torso{width:48px;height:50px;background:linear-gradient(180deg,#7080a8,#5060a8);position:relative;border-radius:2px;border:2px solid #3050a8;display:flex;align-items:center;justify-content:center}
            .k-torso::before{content:'✦';color:var(--gold);font-size:.7rem;text-shadow:0 0 8px var(--gold)}
            .k-torso::after{content:'';position:absolute;left:-14px;top:2px;width:12px;height:42px;background:linear-gradient(180deg,#8898c8,#6878c8);border-radius:2px;border:1.5px solid #4060c0}
            .k-legs{display:flex;gap:4px;margin-top:2px}
            .k-leg{width:18px;height:36px;background:linear-gradient(180deg,#6070a0,#4050a0);border-radius:2px;border:1.5px solid #3040a0;position:relative}
            .k-leg::after{content:'';position:absolute;bottom:-8px;left:-3px;width:24px;height:10px;background:linear-gradient(180deg,#505060,#303040);border-radius:2px;border:1px solid #202030}
            .k-sword{position:absolute;right:-50px;top:10px;transform-origin:top left;transition:transform .2s}
            .k-sword.attacking{animation:swordSwing .4s ease forwards}
            @@keyframes swordSwing{0%{transform:rotate(-30deg)}40%{transform:rotate(50deg)}70%{transform:rotate(20deg)}100%{transform:rotate(-30deg)}}
            .k-shield{position:absolute;left:-22px;top:5px;width:20px;height:28px;background:linear-gradient(135deg,#3060c0,#1040a0);border-radius:4px 4px 6px 6px;border:2px solid #6090e0;display:flex;align-items:center;justify-content:center}
            .k-shield::after{content:'✦';color:rgba(240,192,64,.7);font-size:.5rem}
            .k-shield.blocking{animation:shieldPulse .3s ease infinite alternate}
             @@keyframes shieldPulse{0%{box-shadow:0 0 8px #4080ff,0 0 20px rgba(64,128,255,.4)}100%{box-shadow:0 0 20px #80a8ff,0 0 40px rgba(128,168,255,.6)}}
            /* ENEMY TYPES */
            .skeleton-body{display:flex;flex-direction:column;align-items:center}
            .sk-head{width:28px;height:30px;background:#d0ccc0;border-radius:50% 50% 40% 40%;position:relative;display:flex;align-items:center;justify-content:center;border:2px solid #9090a0}
            .sk-head::before{content:'';position:absolute;top:9px;left:5px;width:6px;height:5px;background:#1a1a2a;border-radius:50%;box-shadow:9px 0 0 #1a1a2a}
            .sk-head::after{content:'';position:absolute;bottom:4px;left:7px;width:14px;height:3px;background:rgba(0,0,0,.5);border-radius:2px}
            .sk-torso{width:30px;height:38px;position:relative;display:flex;align-items:center;justify-content:center}
            .sk-torso::before{content:'';position:absolute;left:5px;top:0;width:4px;height:38px;background:#c8c4b8;border-radius:2px}
            .sk-rib{position:absolute;height:3px;background:#b8b4a8;border-radius:2px}
            .sk-ax{position:absolute;left:-38px;top:0;transform-origin:center right}
            .sk-ax.attacking{animation:axSwing .45s ease forwards}
             @@keyframes axSwing{0%{transform:rotate(20deg)}50%{transform:rotate(-60deg)}100%{transform:rotate(20deg)}}
            .sk-fire{position:absolute;top:-30px;left:50%;transform:translateX(-50%);font-size:1.4rem;animation:fireSpin .8s ease infinite alternate;filter:drop-shadow(0 0 10px #ff4400);opacity:0;pointer-events:none}
             @@keyframes fireSpin{0%{transform:translateX(-50%) scale(1) rotate(-10deg)}100%{transform:translateX(-50%) scale(1.3) rotate(10deg)}}
            .sk-fire.active{opacity:1}
            /* DRAGON */
            .dragon-body{display:flex;flex-direction:column;align-items:center;position:relative;transform-origin:bottom center;animation:dragonFloat 2s ease-in-out infinite}
            @@keyframes dragonFloat{0%,100%{transform:translateY(0) scaleX(1)}50%{transform:translateY(-15px) scaleX(1.02)}}
            .dr-wings{position:absolute;top:10px;width:140px;display:flex;justify-content:space-between;animation:wingsFlap .5s ease-in-out infinite alternate}
             @@keyframes wingsFlap{0%{transform:scaleY(1)}100%{transform:scaleY(.7)}}
            .dr-wing{width:55px;height:50px;background:linear-gradient(135deg,#8a0030,#600020);clip-path:polygon(50% 0%,100% 80%,80% 100%,0% 60%);border:1px solid rgba(200,0,60,.4)}
            .dr-head{width:60px;height:45px;background:linear-gradient(135deg,#c00038,#8a0028);border-radius:8px 16px 8px 12px;position:relative;border:2px solid rgba(220,0,60,.5)}
            .dr-head::before{content:'';position:absolute;top:12px;left:10px;width:10px;height:7px;background:rgba(255,200,0,.8);border-radius:50%;box-shadow:14px 0 0 rgba(255,200,0,.8)}
            .dr-head::after{content:'';position:absolute;top:-12px;left:8px;width:8px;height:16px;background:linear-gradient(180deg,#a00028,#800020);border-radius:2px;box-shadow:18px 0 0 #a00028}
            .dr-torso{width:70px;height:65px;background:linear-gradient(180deg,#a00030,#700020);border-radius:8px;position:relative;border:2px solid rgba(200,0,50,.4);display:flex;align-items:center;justify-content:center}
            .dr-torso::before{content:'';position:absolute;left:0;right:0;top:5px;bottom:5px;display:flex;flex-direction:column;gap:6px}
            .dr-fire{position:absolute;left:-80px;top:5px;font-size:2rem;animation:drFire .3s infinite alternate;filter:drop-shadow(0 0 15px #ff6600) drop-shadow(0 0 30px #ff2200);opacity:0;pointer-events:none}
             @@keyframes drFire{0%{transform:scaleX(1) scaleY(.9)}100%{transform:scaleX(1.2) scaleY(1.1)}}
            .dr-fire.active{opacity:1}
            /* PROJECTILES */
            .projectile{position:absolute;font-size:1.6rem;z-index:8;pointer-events:none;animation:projectileArc linear forwards}
            @@keyframes projectileArc{0%{opacity:1}100%{opacity:.5}}
            /* COMBAT LOG */
            .combat-log{position:absolute;bottom:90px;right:10px;width:220px;background:rgba(0,0,0,.75);border:1px solid rgba(240,192,64,.2);border-radius:8px;padding:.5rem;max-height:100px;overflow-y:auto;z-index:9}
            .combat-log p{font-size:.7rem;color:var(--gray);margin-bottom:.2rem;line-height:1.3}
            .combat-log p.dmg{color:var(--red)}
            .combat-log p.heal{color:var(--green)}
            .combat-log p.block{color:var(--blue)}
            .combat-log p.fire{color:var(--orange)}
            /* STATS PANELS */
            .stats-panels{position:absolute;bottom:90px;left:8px;right:240px;display:flex;justify-content:space-between;z-index:9;pointer-events:none}
            .stat-panel{background:rgba(0,0,0,.8);border:1px solid rgba(240,192,64,.2);border-radius:8px;padding:.5rem .8rem;min-width:160px;max-width:210px}
            .sp-title{font-family:var(--font-title);font-size:.6rem;letter-spacing:2px;color:var(--gold);text-transform:uppercase;margin-bottom:.4rem;border-bottom:1px solid rgba(240,192,64,.15);padding-bottom:.3rem}
            .sp-row{display:flex;justify-content:space-between;font-size:.7rem;color:var(--gray);padding:.15rem 0}
            .sp-row span:last-child{color:var(--white);font-weight:600}
            /* CONTROLS */
            .game-controls{position:relative;z-index:10;background:rgba(0,0,0,.85);border-top:1px solid rgba(240,192,64,.2);padding:.6rem 1rem;display:flex;align-items:center;justify-content:center;gap:.6rem;flex-shrink:0;flex-wrap:wrap}
            .ctrl-btn{padding:.5rem 1rem;background:linear-gradient(180deg,rgba(40,50,80,.9),rgba(20,25,50,.95));border:1px solid rgba(240,192,64,.3);border-radius:6px;color:var(--white);font-family:var(--font-title);font-size:.7rem;letter-spacing:1.5px;transition:all .25s;min-width:72px;text-align:center}
            .ctrl-btn:hover{border-color:var(--gold);background:rgba(240,192,64,.12);transform:translateY(-2px)}
            .ctrl-btn:active{transform:translateY(0) scale(.96)}
            .ctrl-btn.attack-btn{background:linear-gradient(180deg,rgba(140,20,30,.8),rgba(80,10,15,.9));border-color:rgba(230,57,70,.5);color:#ffaaaa}
            .ctrl-btn.attack-btn:hover{background:rgba(230,57,70,.25);border-color:var(--red)}
            .ctrl-btn.block-btn{background:linear-gradient(180deg,rgba(20,60,140,.8),rgba(10,30,80,.9));border-color:rgba(67,97,238,.5);color:#aabcff}
            .ctrl-btn.block-btn:hover{background:rgba(67,97,238,.2);border-color:var(--blue)}
            .ctrl-btn.pause-btn{border-color:rgba(240,192,64,.5);color:var(--gold)}
            .ctrl-sep{width:1px;height:30px;background:rgba(255,255,255,.1);margin:0 .2rem}
            /* FLASH / DAMAGE */
            .damage-flash{position:absolute;inset:0;background:rgba(230,57,70,.25);pointer-events:none;opacity:0;z-index:20;border-radius:4px;animation:flashFade .4s ease forwards}
             @@keyframes flashFade{0%{opacity:1}100%{opacity:0}}
            .hit-text{position:absolute;font-family:var(--font-title);font-size:1.2rem;font-weight:700;pointer-events:none;z-index:15;animation:hitFloat 1s ease forwards}
             @@keyframes hitFloat{0%{opacity:1;transform:translateY(0)}100%{opacity:0;transform:translateY(-60px)}}
            /* OVERLAY (pause, win, lose) */
            .game-overlay{position:absolute;inset:0;background:rgba(0,0,0,.85);display:none;align-items:center;justify-content:center;z-index:30;flex-direction:column;gap:1.5rem;backdrop-filter:blur(4px)}
            .game-overlay.show{display:flex}
            .overlay-title{font-family:var(--font-title);font-size:3rem;font-weight:900;letter-spacing:4px}
            .overlay-sub{color:var(--gray);font-size:1rem;letter-spacing:1px}
            .overlay-btns{display:flex;gap:1rem;flex-wrap:wrap;justify-content:center}
            .overlay-btn{padding:.7rem 2rem;border:1px solid;border-radius:6px;font-family:var(--font-title);font-size:.9rem;letter-spacing:2px;transition:all .3s;cursor:pointer}
            .ob-gold{background:rgba(240,192,64,.15);border-color:var(--gold);color:var(--gold)}
            .ob-gold:hover{background:rgba(240,192,64,.3)}
            .ob-red{background:rgba(230,57,70,.1);border-color:var(--red);color:var(--red)}
            .ob-red:hover{background:rgba(230,57,70,.25)}
            .ob-green{background:rgba(6,214,160,.1);border-color:var(--green);color:var(--green)}
            .ob-green:hover{background:rgba(6,214,160,.25)}
            /* NOTIFICATION */
            .notif{position:fixed;top:1rem;right:1rem;padding:.8rem 1.5rem;border-radius:8px;font-size:.85rem;z-index:9999;animation:notifIn .3s ease,notifOut .4s ease 2.5s forwards;pointer-events:none;border:1px solid;backdrop-filter:blur(10px)}
            @@keyframes notifIn{0%{transform:translateX(100px);opacity:0}100%{transform:translateX(0);opacity:1}}
           @@keyframes notifOut{0%{opacity:1}100%{opacity:0}}
            .notif-success{background:rgba(6,214,160,.15);border-color:var(--green);color:var(--green)}
            .notif-error{background:rgba(230,57,70,.15);border-color:var(--red);color:var(--red)}
            .notif-info{background:rgba(240,192,64,.12);border-color:var(--gold);color:var(--gold)}

            /* scrollbar */
            ::-webkit-scrollbar{width:4px}::-webkit-scrollbar-track{background:transparent}::-webkit-scrollbar-thumb{background:rgba(240,192,64,.3);border-radius:4px}
            /* section hidden */
            .sec-hidden{display:none}
    </style>
</head>
<body>

    <!-- ==================== LANDING PAGE ==================== -->
    <div id="pg-landing" class="page active">
        <div class="lnd-stars" id="lndStars"></div>
        <div class="lnd-particles" id="lndParticles"></div>
        <div class="lnd-ground"></div>
        <div class="lnd-content">
            <div class="lnd-knights"><span>🛡️</span><span>⚔️</span><span>🗡️</span></div>
            <h1 class="lnd-title">IRON CRUSADE</h1>
            <p class="lnd-sub">Knight&apos;s Battle</p>
            <div class="lnd-sword">⚔️</div>
            <p style="color:var(--gray);font-size:.85rem;letter-spacing:2px;max-width:400px;text-align:center">Battle through three deadly levels. Face Skeletons, mighty Warriors, and the fearsome Dragon.</p>
            <button class="lnd-btn" onclick="goToAuth()">⚔ ENTER THE BATTLE ⚔</button>
        </div>
    </div>

    <!-- ==================== AUTH PAGE ==================== -->
    <div id="pg-auth" class="page">
        <div class="auth-wrap">
            <div class="auth-logo">
                <div class="auth-logo-icon">⚔️</div>
                <div class="auth-logo-title">IRON CRUSADE</div>
            </div>
            <div class="auth-tabs">
                <button class="auth-tab active" id="tab-login" onclick="switchAuthTab('login')">LOGIN</button>
                <button class="auth-tab" id="tab-reg" onclick="switchAuthTab('register')">REGISTER</button>
            </div>
            <!-- Login Form -->
            <div class="auth-form" id="form-login">
                <div>
                    <div class="auth-label">Username</div>
                    <input type="text" id="login-user" class="auth-input" placeholder="Enter your username">
                </div>
                <div>
                    <div class="auth-label">Password</div>
                    <input type="password" id="login-pass" class="auth-input" placeholder="Enter your password">
                </div>
                <button class="auth-submit" onclick="doLogin()">⚔ ENTER BATTLE</button>
                <div id="login-msg" class="auth-msg" style="display:none"></div>
            </div>
            <!-- Register Form -->
            <div class="auth-form hidden" id="form-reg">
                <div>
                    <div class="auth-label">Username</div>
                    <input type="text" id="reg-user" class="auth-input" placeholder="Choose a username">
                </div>
                <div>
                    <div class="auth-label">Email</div>
                    <input type="email" id="reg-email" class="auth-input" placeholder="your@email.com">
                </div>
                <div>
                    <div class="auth-label">Password</div>
                    <input type="password" id="reg-pass" class="auth-input" placeholder="Create password">
                </div>
                <button class="auth-submit" onclick="doRegister()">⚔ JOIN THE CRUSADE</button>
                <div id="reg-msg" class="auth-msg" style="display:none"></div>
            </div>
        </div>
    </div>

    <!-- ==================== MAIN APP ==================== -->
    <div id="pg-main" class="page">
        <!-- LEFT DRAWER -->
        <nav class="drawer">
            <div class="drawer-header">
                <div class="drawer-game-title">⚔ IRON CRUSADE</div>
                <div class="drawer-user">
                    <div class="drawer-avatar" id="drawer-avatar">?</div>
                    <div class="drawer-username" id="drawer-username">Player</div>
                </div>
            </div>
            <div class="drawer-nav">
                <button class="drawer-link active" onclick="showSection('home')" id="dl-home"><span>🏰</span><span>Home</span></button>
                <button class="drawer-link" onclick="showSection('profile')" id="dl-profile"><span>👤</span><span>Profile</span></button>
                <button class="drawer-link" onclick="showSection('settings')" id="dl-settings"><span>⚙️</span><span>Settings</span></button>
            </div>
            <div class="drawer-bottom">
                <button class="drawer-logout" onclick="doLogout()">🚪 Logout</button>
            </div>
        </nav>

        <!-- CONTENT AREA -->
        <main class="main-content">

            <!-- HOME SECTION -->
            <section id="sec-home">
                <div class="home-hero">
                    <h2 class="home-hero-title">⚔ Choose Your Battle</h2>
                    <p class="home-hero-sub">Pick a level and enter the arena. Can you survive all three?</p>
                    <div class="home-stats-row">
                        <div class="home-stat"><div class="home-stat-val" id="hs-wins">0</div><div class="home-stat-lbl">Wins</div></div>
                        <div class="home-stat"><div class="home-stat-val" id="hs-losses">0</div><div class="home-stat-lbl">Losses</div></div>
                        <div class="home-stat"><div class="home-stat-val" id="hs-matches">0</div><div class="home-stat-lbl">Matches</div></div>
                        <div class="home-stat"><div class="home-stat-val" id="hs-streak">0</div><div class="home-stat-lbl">Streak</div></div>
                    </div>
                </div>

                <h3 class="levels-title">⚔ SELECT LEVEL</h3>
                <div class="levels-grid">
                    <!-- Level 1 -->
                    <div class="level-card lc-easy">
                        <div class="lc-banner">
                            <div class="lc-icon">💀</div>
                            <div class="lc-info">
                                <div class="lc-level-tag">Level 1 · Easy</div>
                                <div class="lc-name">The Skeleton Crypt</div>
                            </div>
                        </div>
                        <div class="lc-badge badge-new">NEW</div>
                        <div class="lc-body">
                            <p class="lc-desc">A lone skeleton armed with a bone axe rises from the crypt. Fire flies from its sockets — but it is slow and weak. Perfect for beginners.</p>
                            <div class="lc-features">
                                <div class="lc-feat">Enemy HP: 80 · Speed: Slow</div>
                                <div class="lc-feat">Fireball attack every 4s</div>
                                <div class="lc-feat">Shield blocks all fireballs</div>
                                <div class="lc-feat">Knight HP: 150</div>
                            </div>
                            <button class="lc-play-btn" onclick="startGame(1)">⚔ PLAY LEVEL 1</button>
                        </div>
                    </div>
                    <!-- Level 2 -->
                    <div class="level-card lc-medium">
                        <div class="lc-banner">
                            <div class="lc-icon">💂</div>
                            <div class="lc-info">
                                <div class="lc-level-tag">Level 2 · Medium</div>
                                <div class="lc-name">The Undead Warrior</div>
                            </div>
                        </div>
                        <div class="lc-badge badge-hot">HOT</div>
                        <div class="lc-body">
                            <p class="lc-desc">A fearsome undead warrior with armored bones and a heavy axe. Attacks faster and hits harder. Fireballs come in bursts of two!</p>
                            <div class="lc-features">
                                <div class="lc-feat">Enemy HP: 130 · Speed: Medium</div>
                                <div class="lc-feat">Double fireball every 3s</div>
                                <div class="lc-feat">Heavy axe: 18–25 dmg</div>
                                <div class="lc-feat">Knight HP: 120</div>
                            </div>
                            <button class="lc-play-btn" onclick="startGame(2)">⚔ PLAY LEVEL 2</button>
                        </div>
                    </div>
                    <!-- Level 3 -->
                    <div class="level-card lc-hard">
                        <div class="lc-banner">
                            <div class="lc-icon">🐉</div>
                            <div class="lc-info">
                                <div class="lc-level-tag">Level 3 · Hard</div>
                                <div class="lc-name">The Dragon's Lair</div>
                            </div>
                        </div>
                        <div class="lc-body">
                            <p class="lc-desc">The ancient dragon awakens. Massive wings, scorching flames, and armor that your sword barely scratches. Good luck, Knight.</p>
                            <div class="lc-features">
                                <div class="lc-feat">Enemy HP: 200 · Speed: Fast</div>
                                <div class="lc-feat">Inferno blast every 2s</div>
                                <div class="lc-feat">Dragon: 25–40 dmg per hit</div>
                                <div class="lc-feat">Knight HP: 100</div>
                            </div>
                            <button class="lc-play-btn" onclick="startGame(3)">⚔ PLAY LEVEL 3</button>
                        </div>
                    </div>
                </div>

                <!-- REVIEWS -->
                <div class="reviews-section">
                    <h3 class="reviews-title">⚔ Player Reviews</h3>
                    <div class="reviews-grid">
                        <div class="review-card">
                            <div class="rv-header">
                                <div class="rv-avatar" style="background:linear-gradient(135deg,#3a1a6a,#7b2fbe);color:#d8aaff">AR</div>
                                <div><div class="rv-name">ArhamRaza</div><div class="rv-stars">★★★★★</div></div>
                            </div>
                            <p class="rv-text">"The dragon level is insane! Shield timing is everything. Took me 20 tries but finally beat it. Best browser game ever!"</p>
                        </div>
                        <div class="review-card">
                            <div class="rv-header">
                                <div class="rv-avatar" style="background:linear-gradient(135deg,#0a3a6a,#4361ee);color:#aac4ff">SK</div>
                                <div><div class="rv-name">SaraMKhan</div><div class="rv-stars">★★★★☆</div></div>
                            </div>
                            <p class="rv-text">"Love the skeleton animations and the fire effects. The combat feels really satisfying. Level 2 difficulty is perfect."</p>
                        </div>
                        <div class="review-card">
                            <div class="rv-header">
                                <div class="rv-avatar" style="background:linear-gradient(135deg,#1a4a1a,#06d6a0);color:#aaffda">ZH</div>
                                <div><div class="rv-name">ZaidHaq</div><div class="rv-stars">★★★★★</div></div>
                            </div>
                            <p class="rv-text">"The stats panel on the left showing flex properties is such a cool touch. Feels like a real game engine preview!"</p>
                        </div>
                        <div class="review-card">
                            <div class="rv-header">
                                <div class="rv-avatar" style="background:linear-gradient(135deg,#4a1a1a,#e63946);color:#ffaaaa">FN</div>
                                <div><div class="rv-name">FaizaNoor</div><div class="rv-stars">★★★★☆</div></div>
                            </div>
                            <p class="rv-text">"The dark/light theme switch is smooth. Profile page shows all my wins. Would love more levels though!"</p>
                        </div>
                    </div>
                </div>
            </section>

            <!-- PROFILE SECTION -->
            <section id="sec-profile" class="sec-hidden">
                <div class="profile-card">
                    <div class="profile-avatar-big" id="prof-avatar">?</div>
                    <div class="profile-info">
                        <div class="profile-name-big" id="prof-name">Player</div>
                        <div class="profile-role">🛡️ Knight of the Crusade</div>
                        <div class="profile-date">Joined: <span id="prof-join">—</span></div>
                        <div class="profile-date">Last Login: <span id="prof-login">—</span></div>
                        <div class="profile-date">Email: <span id="prof-email">—</span></div>
                    </div>
                </div>
