@code {
    private enum ViewState { Auth, MainApp, GameScreen }
    private ViewState CurrentView { get; set; } = ViewState.Auth;
    private string ActiveTab { get; set; } = "home";
    private bool IsLoginTab { get; set; } = true;

    // Custom Themes Bound Properties    
    private bool IsDarkStyle { get; set; } = true;
    private bool IsLightStyle { get; set; } = false;
    private bool IsColorblindStyle { get; set; } = false;

    // Input Element Binding Targets    
    private string AuthUsername { get; set; } = string.Empty;
    private string AuthEmail { get; set; } = string.Empty;
    private string AuthPassword { get; set; } = string.Empty;
    private string AuthErrorMessage { get; set; } = string.Empty;
    private string AuthSuccessMessage { get; set; } = string.Empty; // Fixed: Green alert track karne ke liye

    private User? CurrentUser { get; set; }
    private List<MatchHistory> MatchHistories { get; set; } = new();
    private List<NotificationItem> Notifications { get; set; } = new();
    private List<HitTextInstance> LiveHitTexts { get; set; } = new();

    private bool ShouldFlashScreen { get; set; } = false;
    private bool IsCurrentGameVictory { get; set; } = false;

    private int warriorWeaponAngle { get; set; } = 0;

    // TEMPORARY IN-MEMORY DB SIMULATION    
    private static List<User> InMemoryUsers = new List<User>();
    private static List<MatchHistory> InMemoryMatches = new List<MatchHistory>();

    private string UserInitials => CurrentUser != null && CurrentUser.Username.Length >= 2
        ? CurrentUser.Username[..2].ToUpper() : "??";

    private bool IsAppScreenActive => CurrentView == ViewState.MainApp;

    private string OverlayTitle => Engine.State!.Paused && !Engine.State.Over ? "⏸ PAUSED"
        : (IsCurrentGameVictory ? "⚔ VICTORY!" : "💀 DEFEATED!");

    private string OverlaySubtitle => Engine.State!.Paused && !Engine.State.Over ? "Take a breath, Knight"
        : (IsCurrentGameVictory ? $"You conquered the trial! Score: {Engine.State.Score} pts"
                                : "The enemy domain was too treacherous...");

    protected override void OnInitialized()
    {
        Engine.OnStateChanged += RefreshUI;
        Engine.OnGameEnded += HandleGameCompletion;
        Engine.OnScreenFlash += TriggerFlashEffect;
        Engine.OnHitTextCreated += AddHitTextElement;
    }

    private void RefreshUI() => InvokeAsync(StateHasChanged);

    // Tab controllers to manage view toggles cleanly
    private void SwitchToLoginTab()
    {
        IsLoginTab = true;
        ResetAuthFields();
    }

    private void SwitchToRegisterTab()
    {
        IsLoginTab = false;
        ResetAuthFields();
    }

    private void ResetAuthFields()
    {
        AuthErrorMessage = string.Empty;
        AuthSuccessMessage = string.Empty;
        AuthPassword = string.Empty;
    }

    private void SetTab(string tabName)
    {
        ActiveTab = tabName;
        if (tabName == "profile") LoadUserChronicles();
    }

    // --- 100% FIXED LOGIN FLOW ---
    private void HandleLogin()
    {
        AuthErrorMessage = string.Empty;
        AuthSuccessMessage = string.Empty;

        if (string.IsNullOrWhiteSpace(AuthUsername) || string.IsNullOrWhiteSpace(AuthPassword))
        {
            AuthErrorMessage = "Username and Password cannot be blank.";
            return;
        }

        string encodedPass = Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(AuthPassword));
        
        var matchedUser = InMemoryUsers.FirstOrDefault(u => u.Username.ToLower() == AuthUsername.Trim().ToLower()
            && u.PasswordHash == encodedPass);

        if (matchedUser != null)
        {
            CurrentUser = matchedUser;
            CurrentUser.LastLogin = DateTime.Now.ToString("g");
            TransitionToMainApp();
        }
        else
        {
            AuthErrorMessage = "Invalid credentials standard challenge failed. Please sign up or check password.";
        }
    }

    // --- 100% FIXED REGISTRATION FLOW ---
    private void HandleRegister()
    {
        AuthErrorMessage = string.Empty;
        AuthSuccessMessage = string.Empty;

        // 1. Check for empty fields
        if (string.IsNullOrWhiteSpace(AuthUsername) || string.IsNullOrWhiteSpace(AuthEmail) || string.IsNullOrWhiteSpace(AuthPassword))
        {
            AuthErrorMessage = "All registration fields are required.";
            return;
        }

        // 2. Simplified robust email verification
        string cleanedEmail = AuthEmail.Trim();
        if (!cleanedEmail.Contains("@") || !cleanedEmail.Contains(".") || cleanedEmail.IndexOf("@") > cleanedEmail.LastIndexOf("."))
        {
            AuthErrorMessage = "Invalid Email! Must include '@' and a domain extension (e.g., knight@gmail.com).";
            return;
        }

        // 3. Password length validation
        if (AuthPassword.Length < 8)
        {
            AuthErrorMessage = "Security Breach! Password must be at least 8 characters long.";
            return;
        }

        // 4. Duplicate identity validation
        if (InMemoryUsers.Any(u => u.Username.ToLower() == AuthUsername.Trim().ToLower()))
        {
            AuthErrorMessage = "Username already verified in another house. Try another name.";
            return;
        }

        // 5. Save operation
        string encodedPass = Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(AuthPassword));

        var newUser = new User
        {
            Username = AuthUsername.Trim(),
            Email = cleanedEmail,
            PasswordHash = encodedPass
        };

        InMemoryUsers.Add(newUser);

        // 6. Redirect execution flow to login view instead of immediate bypass
        AuthSuccessMessage = "Account forged successfully! Log in below with your credentials.";
        IsLoginTab = true; // Auto switches to login view
        AuthPassword = string.Empty; // Wipes out password field for safety
    }

    private void TransitionToMainApp()
    {
        CurrentView = ViewState.MainApp;
        ActiveTab = "home";
        _ = TriggerNotification($"Welcome to the Citadel, {CurrentUser?.Username}!", "info");
    }

    private void LoadUserChronicles()
    {
        if (CurrentUser != null)
        {
            MatchHistories = InMemoryMatches
                .Where(m => m.UserId == CurrentUser.Id)
                .OrderByDescending(m => m.Id)
                .Take(15)
                .ToList();
        }
    }

    private void StartBattle(int level)
    {
        CurrentView = ViewState.GameScreen;
        Engine.StartGame(level);
    }

    private void HandleGameCompletion(bool won)
    {
        IsCurrentGameVictory = won;
        if (CurrentUser != null && Engine.State != null)
        {
            if (won)
            {
                CurrentUser.Wins++;
                CurrentUser.Streak++;
                if (CurrentUser.Streak > CurrentUser.BestStreak) CurrentUser.BestStreak = CurrentUser.Streak;
                if (Engine.State.Level == 3) CurrentUser.DragonKills++;
            }
            else
            {
                CurrentUser.Losses++;
                CurrentUser.Streak = 0;
            }

            var record = new MatchHistory
            {
                UserId = CurrentUser.Id,
                Level = Engine.State.Level,
                Enemy = GameEngineService.Levels[Engine.State.Level].Label,
                Result = won ? "WIN" : "LOSE"
            };

            InMemoryMatches.Add(record);
        }
        RefreshUI();
    }

    private void ExitGameToCitadel()
    {
        Engine.Dispose();
        CurrentView = ViewState.MainApp;
        ActiveTab = "home";
    }

    private int CalculateHpPercentage(int current, int max) => (int)((double)current / max * 100);

    private string GetHpBarColor(int current, int max)
    {
        double pct = (double)current / max * 100;
        if (pct < 25) return "linear-gradient(90deg,#8a0f0f, #e63946)";
        if (pct < 50) return "linear-gradient(90deg,#8a5a00, #fb8500)";
        return "linear-gradient(90deg,#1a7a3a, #2a9d8f)";
    }

    private async void TriggerFlashEffect()
    {
        ShouldFlashScreen = true;
        await InvokeAsync(StateHasChanged);
        await Task.Delay(400);
        ShouldFlashScreen = false;
        await InvokeAsync(StateHasChanged);
    }

    private async void AddHitTextElement(string text, string color, bool isEnemy)
    {
        var instance = new HitTextInstance { Text = text, Color = color, IsEnemy = isEnemy, Top = new Random().Next(35, 55) };
        LiveHitTexts.Add(instance);
        await InvokeAsync(StateHasChanged);

        await Task.Delay(1100);
        LiveHitTexts.Remove(instance);
        await InvokeAsync(StateHasChanged);
    }

    private async Task TriggerNotification(string msg, string type)
    {
        var item = new NotificationItem { Message = msg, Type = type };
        Notifications.Add(item);
        await InvokeAsync(StateHasChanged);

        await Task.Delay(3200);
        Notifications.Remove(item);
        await InvokeAsync(StateHasChanged);
    }

    private void ToggleDark() { IsDarkStyle = true; IsLightStyle = false; }
    private void ToggleLight() { IsLightStyle = true; IsDarkStyle = false; }
    private void ToggleColorblind(ChangeEventArgs e) => IsColorblindStyle = (bool)(e.Value ?? false);

    public void LogOut()
    {
        CurrentUser = null;
        CurrentView = ViewState.Auth;
    }

    public void Dispose()
    {
        Engine.OnStateChanged -= RefreshUI;
        Engine.OnGameEnded -= HandleGameCompletion;
        Engine.OnScreenFlash -= TriggerFlashEffect;
        Engine.OnHitTextCreated -= AddHitTextElement;
    }

    private class NotificationItem { public string Message { get; set; } = ""; public string Type { get; set; } = ""; }
    private class HitTextInstance { public string Text { get; set; } = ""; public string Color { get; set; } = ""; public bool IsEnemy { get; set; } public int Top { get; set; } }
}
