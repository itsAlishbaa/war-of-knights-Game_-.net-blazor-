                        }
                        else if (config.Enemy == "dragon")
                        {
                            <svg width="210" height="210" viewBox="0 0 190 190" xmlns="http://www.w3.org/2000/svg">
                                <ellipse cx="95" cy="170" rx="60" ry="12" fill="rgba(0,0,0,0.6)" />
                                <path d="M85 85 C35 25, 5 55, 0 115 C20 105, 50 105, 85 100 Z" fill="#781D1D" stroke="#3A0505" stroke-width="2.5" />
                                <path d="M105 85 C155 25, 185 55, 190 115 C170 105, 140 105, 105 100 Z" fill="#781D1D" stroke="#3A0505" stroke-width="2.5" />
                                <ellipse cx="95" cy="120" rx="34" ry="45" fill="#A82323" stroke="#4A0E0E" stroke-width="4" />
                                <g transform="translate(105,40)">
                                    <path d="M-12 -6 L25 -25 L45 2 L25 18 L-12 12 Z" fill="#FF2E2E" stroke="#4A0E0E" stroke-width="2" />
                                    <circle cx="10" cy="-2" r="5" fill="#FFEE58" filter="drop-shadow(0 0 5px #FFA000)" />
                                </g>
                            </svg>
                        }

                        @* FIREBALL PROJECTILE *@
                        @if (Engine.IsProjectileActive)
                        {
                            <div class="sk-fire" style="position:absolute !important; left: -@(Engine.ProjectilePosition * 2.2)px !important; bottom: 80px !important; transition: left 0.04s linear !important; font-size: 3rem !important; text-shadow: 0 0 30px #FF3D00 !important; z-index: 5 !important;">🔥</div>
                        }
                    </div>
                    <div class="fighter-label" style="text-align:center !important; font-weight:bold !important; color:#fff !important; margin-top:5px !important; text-shadow: 2px 2px 4px #000 !important; font-size:1.1rem !important;">@config.Label.ToUpper()</div>
                </div>

                @* LIVE COMBAT RADAR LOGS (Dialogue Box Centered) *@
                <div class="combat-log" style="position: absolute !important; bottom: 25px !important; left: 50% !important; transform: translateX(-50%) !important; text-align: center !important; background: rgba(11, 17, 30, 0.9) !important; width: 60% !important; max-width: 700px !important; padding: 15px 30px !important; border-radius: 8px !important; z-index: 4 !important; border: 2px solid #1e293b !important; box-shadow: 0 10px 25px rgba(0,0,0,0.6) !important;">
                    @foreach (var log in Engine.CombatLog.Take(1))
                    {
                        <p class="log-entry" style="margin:0 !important; color:#fff !important; font-size:1.2rem !important; font-weight:bold !important; font-family: monospace !important; letter-spacing: 0.5px !important; line-height: 1.4 !important;">@log</p>
                    }
                </div>

                @* DAMAGE FLASH SCREEN ELEMENT *@
                <div class="damage-flash @(ShouldFlashScreen ? "active-flash" : "")" style="z-index: 8 !important; position:absolute !important; top:0 !important; left:0 !important; width:100% !important; height:100% !important; pointer-events:none !important;"></div>

                @* OVERLAYS *@
                @if (Engine.State.Over || Engine.State.Paused)
                {
                    <div class="game-overlay show" style="z-index: 200000 !important; position: absolute !important; top:0 !important; left:0 !important; width:100% !important; height:100% !important; background:rgba(7, 11, 20, 0.95) !important; display:flex !important; flex-direction:column !important; justify-content:center !important; align-items:center !important;">
                        <div class="overlay-title" style="color:#ffb703 !important; font-size:3.5rem !important; font-weight:bold !important; margin-bottom:10px !important; letter-spacing:2px !important; text-shadow: 0 0 20px rgba(255,183,3,0.4) !important;">@OverlayTitle</div>
                        <div class="overlay-sub" style="color:#94a3b8 !important; font-size:1.5rem !important; margin-bottom:30px !important;">@OverlaySubtitle</div>
                        <div class="overlay-btns" style="display:flex !important; gap:20px !important;">
                            @if (Engine.State.Paused && !Engine.State.Over)
                            {
                                <button class="overlay-btn ob-gold" style="padding:14px 32px !important; font-weight:bold !important; font-size:1.1rem !important; cursor:pointer !important; border-radius:6px !important; border:none !important; background:#ffb703 !important; color:#000 !important;" @onclick="Engine.TogglePause">▶ RESUME</button>
                            }
                            @if (Engine.State.Over && Engine.State.Level < 3 && IsCurrentGameVictory)
                            {
                                <button class="overlay-btn ob-green" style="padding:14px 32px !important; font-weight:bold !important; font-size:1.1rem !important; cursor:pointer !important; border-radius:6px !important; border:none !important; background:#22c55e !important; color:#fff !important;" @onclick="() => StartBattle(Engine.State.Level + 1)">▶ NEXT LEVEL</button>
                            }
                            @if (Engine.State.Over)
                            {
                                <button class="overlay-btn ob-gold" style="padding:14px 32px !important; font-weight:bold !important; font-size:1.1rem !important; cursor:pointer !important; border-radius:6px !important; border:none !important; background:#ffb703 !important; color:#000 !important;" @onclick="() => StartBattle(Engine.State.Level)">↺ REPLAY</button>
                            }
                            <button class="overlay-btn ob-red" style="padding:14px 32px !important; font-weight:bold !important; font-size:1.1rem !important; cursor:pointer !important; border-radius:6px !important; border:none !important; background:#ef4444 !important; color:#fff !important;" @onclick="ExitGameToCitadel">✕ EXIT</button>
                        </div>
                    </div>
                }
            </div>
        </div>

        @* BOTTOM INTERACTIVE BUTTON CONTROLS *@
        <div class="game-controls" style="background: #070b14 !important; padding: 25px !important; display: flex !important; justify-content: center !important; gap: 15px !important; border-top: 3px solid #1e293b !important; box-shadow: 0 -10px 25px rgba(0,0,0,0.5) !important; width: 100% !important; box-sizing: border-box !important;">
            <button class="ctrl-btn" style="padding:12px 24px !important; cursor:pointer !important; font-size:1rem !important; font-weight:bold !important; background:#1e293b !important; color:#fff !important; border:1px solid #475569 !important; border-radius:6px !important;" @onclick="() => Engine.MoveKnight(-1)">◀ BACKWARD</button>
            <button class="ctrl-btn" style="padding:12px 24px !important; cursor:pointer !important; font-size:1rem !important; font-weight:bold !important; background:#1e293b !important; color:#fff !important; border:1px solid #475569 !important; border-radius:6px !important;" @onmousedown="Engine.StartBlock" @onmouseup="Engine.StopBlock" @onmouseleave="Engine.StopBlock">🛡️ BLOCK SHIELD</button>
            <button class="ctrl-btn ctrl-btn-attack" style="background:#ff4757 !important; color:#fff !important; font-weight:bold !important; padding:12px 40px !important; cursor:pointer !important; border:none !important; border-radius:6px !important; font-size:1.1rem !important; box-shadow: 0 0 15px rgba(255,71,87,0.4) !important;" @onclick="Engine.KnightAttack">⚔ ATTACK</button>
            <button class="ctrl-btn" style="padding:12px 24px !important; cursor:pointer !important; font-size:1rem !important; font-weight:bold !important; background:#1e293b !important; color:#fff !important; border:1px solid #475569 !important; border-radius:6px !important;" @onclick="() => Engine.MoveKnight(1)">FORWARD ▶</button>
            <button class="ctrl-btn" style="padding:12px 24px !important; cursor:pointer !important; font-size:1rem !important; font-weight:bold !important; background:#1e293b !important; color:#fff !important; border:1px solid #475569 !important; border-radius:6px !important;" @onclick="Engine.TogglePause">⏸ PAUSE</button>
        </div>
    </div>
}
</main>
